<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 3D 7.0.3" snapToGrid="false">
  <code><![CDATA[breed [ points point ]        ;; TEMPORAL: se eliminará cuando quitemos el paisaje
breed [ particles particle ]  ;; lobos del GWO



globals [
  ;; --- líderes del GWO ---
  alpha-pos          ;; vector de decisión del lobo alpha
  alpha-val          ;; fitness del lobo alpha

  beta-pos           ;; vector de decisión del lobo beta
  beta-val           ;; fitness del lobo beta

  delta-pos          ;; vector de decisión del lobo delta
  delta-val          ;; fitness del lobo delta

  ;; --- datos del problema de reparto ---
  demands            ;; lista de demandas [Qr1 Qr2 ... QrN]
  total-demand       ;; suma total de demandas
  shortage-ratio     ;; available-flow / total-demand

  ;; --- seguimiento ---
  best-history       ;; opcional: guardar histórico del mejor fitness
  max-ticks

  ;; --- temporales viejos del modelo anterior (se quitarán luego) ---
  true-best-patch
  
  
  



  delta-x
  delta-y
  delta-z
  beta-x
  beta-Y
  beta-Z
  alpha-x
  alpha-Y
  alpha-Z
]



patches-own [
  elevation     ;; valor FITNESS asociado a cada parcela (patch)
]



turtles-own [
  fitness
  decision-vector   ;; vector de reparto [Q1 Q2 ... QN]
]



;; Funcion con la que evaluamos los puntos (x, y) dados, nos devuelve la altura (elevation)
to-report objective-function [x y]

  ;; Funcion esfera
  let value  (x ^ 2 + y ^ 2)
  report value
end



to-report better? [a b]
  ;; En este problema SIEMPRE minimizamos
  report a < b
end

to-report worst-sentinel
  ;; Valor inicial muy malo para un problema de minimización
  report 1e+20
end


;; =========================================================
;; NUEVAS FUNCIONES DEL PROBLEMA DE REPARTO DE AGUA
;; =========================================================

;; Construye el vector de demandas en función de la interfaz
to-report build-demands
  let qs []

  if demand-pattern = "uniform" [
    repeat num-turnouts [
      set qs lput base-demand qs
    ]
  ]

  if demand-pattern = "random" [
    repeat num-turnouts [
      ;; variación aleatoria +-30% alrededor de base-demand
      let q base-demand * (0.7 + random-float 0.6)
      set qs lput q qs
    ]
  ]

  if demand-pattern = "upstream-heavy" [
    ;; más demanda al principio del canal
    let i 0
    repeat num-turnouts [
      let factor (1.3 - (0.6 * i / (num-turnouts - 1)))
      set qs lput (base-demand * factor) qs
      set i i + 1
    ]
  ]

  if demand-pattern = "downstream-heavy" [
    ;; más demanda al final del canal
    let i 0
    repeat num-turnouts [
      let factor (0.7 + (0.6 * i / (num-turnouts - 1)))
      set qs lput (base-demand * factor) qs
      set i i + 1
    ]
  ]

  report qs
end


;; Genera una asignación inicial aleatoria y factible
to-report random-feasible-allocation [qr-list q-available]
  let raw []
  repeat length qr-list [
    set raw lput (random-float 1.0) raw
  ]

  let s sum raw
  if s = 0 [
    set raw map [q -> 1] qr-list
    set s sum raw
  ]

  ;; Escalamos al caudal disponible
  let alloc map [x -> x * q-available / s] raw

  ;; Limitamos por demanda máxima
  set alloc (map [[a q] -> min (list a q)] alloc qr-list)
  
  ;; Si tras cortar por demanda sobra agua, de momento la dejamos sin usar
  report alloc
end


;; Garantiza restricciones de factibilidad
to-report enforce-constraints [qd qr-list q-available]
  ;; 1) no negatividad
  let corrected map [x -> max (list 0 x)] qd

  ;; 2) no superar demanda
  set corrected (map [[a q] -> min (list a q)] corrected qr-list)

  ;; 3) suma total <= available-flow
  let s sum corrected
  if s > q-available and s > 0 [
    set corrected map [x -> x * q-available / s] corrected
  ]

  report corrected
end


;; Coeficiente de variación
to-report coeff-variation [xs]
  if empty? xs [ report 0 ]
  let m mean xs
  if m = 0 [ report 0 ]

  let var mean map [x -> (x - m) ^ 2] xs
  report (sqrt var) / m
end


;; Adecuación PA
to-report calc-PA [qd qr-list]
  let s 0
  (foreach qd qr-list [[d r] ->
    ifelse r > 0
      [ set s s + min (list 1 (d / r)) ]
      [ set s s + 1 ]
  ])
  report s / length qr-list
end


;; Eficiencia PF
to-report calc-PF [qd qr-list]
  let s 0
  (foreach qd qr-list [[d r] ->
    ifelse d > 0
      [ set s s + min (list 1 (r / d)) ]
      [ set s s + 1 ]
  ])
  report s / length qr-list
end


;; Equidad PE = coeficiente de variación de Qd/Qr
to-report calc-PE [qd qr-list]
  let ratios []
  (foreach qd qr-list [[d r] ->
    ifelse r > 0
      [ set ratios lput (d / r) ratios ]
      [ set ratios lput 1 ratios ]
  ])
  report coeff-variation ratios
end


;; Dependabilidad PD
;; De momento la dejamos en 0 porque aún no modelamos la dimensión temporal.
to-report calc-PD [qd qr-list]
  report 0
end


;; Fitness del problema de reparto de agua
;; FF = (1 - PA) + (1 - PF) + PE + PD
to-report water-fitness [qd qr-list]

  let adequacy calc-PA qd qr-list
  let efficiency calc-PF qd qr-list
  let equity calc-PE qd qr-list
  let dependability calc-PD qd qr-lisT


  report (1 - adequacy) + (1 - efficiency) + equity + dependability
end

;; inicialza dots canal
to setup-problem-data
  set demands build-demands
  set total-demand sum demands

  ifelse total-demand > 0
    [ set shortage-ratio available-flow / total-demand ]
    [ set shortage-ratio 0 ]

  set best-history []
end



;; Iicializa los líderes 

to initialize-leaders
  update-alpha-beta-delta
end



;; Actualiza alpha/beta/delta con un candidato dado
;; Recibe 
to update-leaders-with [candidate-fitness candidate-pos]

  ifelse (better? candidate-fitness alpha-val) [
    ;; El candidato pasa a alpha, y se desplaza la jerarquía
    set delta-val beta-val
    set delta-pos beta-pos

    set beta-val alpha-val
    set beta-pos alpha-pos

    set alpha-val candidate-fitness
    set alpha-pos candidate-pos

  ] [
    ifelse (better? candidate-fitness beta-val) [
      ;; Mejor que beta pero no que alpha
      set delta-val beta-val
      set delta-pos beta-pos

      set beta-val candidate-fitness
      set beta-pos candidate-pos

    ] [
      ;; Solo mejor que delta
      if (better? candidate-fitness delta-val) [
        set delta-val candidate-fitness
        set delta-pos candidate-pos
      ]
    ]
  ]
end
  
to setup
  clear-all

  set max-ticks ceiling (evaluation-budget / population-size)
  set max-ticks max list 50 min list max-ticks 2000

  ;; Preparar datos del problema
  setup-problem-data

  ;; Visualización simple
  ask patches [
    set pcolor black
  ]

  initialize-particles
  initialize-leaders

  reset-ticks
end






to set-observer-position

  ifelse random-search-space [
    ask patches with [pzcor = max-pzcor] [set pcolor 102]
    setxyz -40 -40 -50
    facexyz -0 -0 10
    orbit-down 100
  ]
  [
    setxyz 50 50 50
    facexyz -0 -0 10
  ]
end


;; Crear espacio de busqueda aleatorio
to create-random-search-space

  ask n-of hills-number patches with [pzcor = 0 ] [ set elevation 50 + random 100 ]  ; elevacion entre 50 y 150
  ;; Suavizar espacio de busqueda segun
  repeat landscape-smoothness [ diffuse elevation 1]

  
  ifelse random-search-space [
      ask max-one-of patches [elevation] [ set true-best-patch self ]
    ] [
      ask min-one-of patches [elevation] [ set true-best-patch self ]
    ]

end


;; Procedimiento para obtener el FITNESS (elevacion)
to-report get-elevation

  ifelse random-search-space
    ;; Aproximamos las coordenadas de la partícula actual porque no conocemos
    ;; la función de FITNESS, pero conocemos la elevación aleatoria dada.
    [
    let ix max list min-pxcor (min list max-pxcor round xcor)
    let iy max list min-pycor (min list max-pycor round ycor)
    report [elevation] of patch ix iy 0
    ]

    ;; En caso de que no utilizar espacio de búsqueda aleatorio, devolvemos el valor de FITNESS exacto
    [report objective-function xcor ycor]

end


;; Dibujar espacion de busqueda
to draw-search-space

  ;; Valor maximo de la funcion objetivo
  let max-elevation max [elevation] of patches with [pzcor = 0]

  ;; Creamos los puntos sobre el espacio para vincularlos
  ask patches with [pzcor = 0]
  [
    sprout-points 1
    [
      create-links-with points-on neighbors
      hide-turtle
    ]
  ]

  ask points
  [
    ;; Dibujamos espacio de búsqueda proporcional al tamaño del mundo
    set zcor (elevation / max-elevation) * max-pzcor
  ]
end


;; Inicializar particulas en el espacio de busqueda
to initialize-particles
  create-particles population-size [

    ;; Generar una solución inicial factible
    set decision-vector random-feasible-allocation demands available-flow

    ;; Evaluar fitness con la nueva función del problema
    set fitness water-fitness decision-vector demands

    ;; Coordenadas solo para visualizar agentes en pantalla
    setxy random-xcor random-ycor

    ;; aspecto visual
    set color red
    set shape "dot"
    set size 2
    pen-up
  ]
end




;; Actualiza quienes son los primeros 3 lobos (alpha, beta y delta)

to update-alpha-beta-delta
  set alpha-val worst-sentinel
  set beta-val worst-sentinel
  set delta-val worst-sentinel

  set alpha-pos []
  set beta-pos []
  set delta-pos []

  ;; Ordenamos todas las partículas de mejor a peor fitness ANTES de actualizar
  ;; los líderes, para que la jerarquía se construya de forma consistente
  ;; independientemente del orden aleatorio en que NetLogo procesa los agentes.
  let ordered-wolves sort-on [fitness] particles
 
  ;; Recorremos las partículas ya ordenadas de mejor a peor.
  ;; Al procesar siempre en este orden, la primera partícula que entre
  ;; será la mejor candidata a alpha, la segunda a beta, y así sucesivamente.
  ;; Los líderes anteriores solo se conservan si ninguna partícula nueva los supera.
  foreach ordered-wolves [ wolf ->
    ask wolf [
      update-leaders-with fitness decision-vector
    ]
  ]
end





to-report gwo-next-position [current-pos a]
  let new-pos []
  let i 0

  repeat length current-pos [
    let x item i current-pos

    let alpha-i item i alpha-pos
    let beta-i  item i beta-pos
    let delta-i item i delta-pos

    ;; ---- Influencia de alpha ----
    let r1a random-float 1
    let r2a random-float 1
    let A1 ((2 * a * r1a) - a)
    let C1 (2 * r2a)

    let d-alpha abs (C1 * alpha-i - x)
    let X1 alpha-i - A1 * d-alpha

    ;; ---- Influencia de beta ----
    let r1b random-float 1
    let r2b random-float 1
    let A2 ((2 * a * r1b) - a)
    let C2 (2 * r2b)

    let d-beta abs (C2 * beta-i - x)
    let X2 beta-i - A2 * d-beta

    ;; ---- Influencia de delta ----
    let r1c random-float 1
    let r2c random-float 1
    let A3 ((2 * a * r1c) - a)
    let C3 (2 * r2c)

    let d-delta abs (C3 * delta-i - x)
    let X3 delta-i - A3 * d-delta

    ;; nueva componente = promedio
    let new-x (X1 + X2 + X3) / 3

    set new-pos lput new-x new-pos
    set i i + 1
  ]

  ;; Aplicar restricciones del problema
  set new-pos enforce-constraints new-pos demands available-flow

  report new-pos
end


to update-particle-visual-position
  ;; Posición visual basada en:
  ;; x = cantidad total repartida
  ;; y = fitness (escalado de forma simple)

  let allocated sum decision-vector
  let fit fitness

  let xvis min list max-pxcor max list min-pxcor (allocated * 10 - 5)
  let yvis min list max-pycor max list min-pycor (5 - fit * 5)

  setxy xvis yvis
end



;; FUNCION PRINCIPAL DE OPTIMIZACION SEGUN EL ALGORITMO
to go
  ;; criterio de parada
  if ticks >= max-ticks [ stop ]

  ;; parámetro a decreciendo linealmente de 2 a 0
  let a 2 * (1 - ((ticks + 1) / (max-ticks * 1.0)))

  ;; actualizar cada lobo
  ask particles [
    let new-decision gwo-next-position decision-vector a
    set decision-vector new-decision
    set fitness water-fitness decision-vector demands

    ;; mover visualización
    update-particle-visual-position
  ]

  ;; actualizar líderes
  update-alpha-beta-delta

  ;; guardar histórico del mejor fitness
  set best-history lput alpha-val best-history

  tick
end
]]></code>
