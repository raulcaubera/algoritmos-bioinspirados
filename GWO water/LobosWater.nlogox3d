    <switch x="742" y="275" height="40" on="false" variable="trace-mode" width="178" display="trace-mode"></switch>
    <slider x="742" step="1" y="197" max="50" width="178" display="hills-number" height="50" min="1" direction="Horizontal" default="29.0" variable="hills-number"></slider>
    <slider x="742" step="1" y="134" max="20" width="176" display="landscape-smoothness" height="50" min="4" direction="Horizontal" default="5.0" variable="landscape-smoothness"></slider>
