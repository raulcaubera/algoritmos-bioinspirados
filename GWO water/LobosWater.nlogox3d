    <monitor x="384" precision="2" y="164" height="60" fontSize="11" width="157" display="Best CH openings"><![CDATA[map [x -> precision x 3] (sublist global-best-pos num-turnouts (num-turnouts + num-check-gates))]]></monitor>
    <monitor x="730" precision="2" y="14" height="60" fontSize="11" width="223" display="Average deliveries"><![CDATA[map [x -> precision x 3] ui-average-deliveries]]></monitor>
