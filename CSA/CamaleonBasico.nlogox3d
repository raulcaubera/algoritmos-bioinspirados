<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 3D 7.0.3" snapToGrid="false">
  <code><![CDATA[; ==========================================================
;  CSA — Algoritmo de Enjambre de Camaleones (NetLogo 3D)
; ==========================================================

breed [ points point ]       ;; puntos para visualizar la superficie (malla 3D)
breed [ particles particle ] ;; agentes camaleones que exploran el espacio

globals [
  g-best-x          ;; mejor X global encontrada
  g-best-y          ;; mejor Y global encontrada
  g-best-val        ;; mejor fitness global
  true-best-patch   ;; (paisaje aleatorio) parche con mayor elevación
]

particles-own [
  vx                ;; velocidad acumulada en X — proyección de lengua (Fase 3)
  vy                ;; velocidad acumulada en Y — proyección de lengua (Fase 3)
  p-best-x          ;; mejor X personal (Pi)
  p-best-y          ;; mejor Y personal (Pi)
  p-best-val        ;; mejor fitness personal
]

patches-own [
  elevation         ;; fitness del parche (visualización / paisaje aleatorio)
]

; ----------------------------------------------------------
; FUNCIÓN OBJETIVO: ESFERA  f(x,y) = x² + y²  (minimizar)
; ----------------------------------------------------------
to-report objective-function [x y]
  report (x ^ 2 + y ^ 2)
end

; ----------------------------------------------------------
; SETUP
; ----------------------------------------------------------
to setup
  clear-all
  ask patches [ set elevation 0 ]

  ifelse random-search-space
  [ create-random-search-space ]
  [ ask patches with [pzcor = 0] [ set elevation (objective-function pxcor pycor) ] ]

  draw-search-space
  initialize-particles
  set-observer-position

  ;; Inicializar mejor global coherente con el modo de optimización
  ifelse random-search-space
  [ ask max-one-of particles [p-best-val]
    [ set g-best-val p-best-val  set g-best-x p-best-x  set g-best-y p-best-y ] ]
  [ ask min-one-of particles [p-best-val]
    [ set g-best-val p-best-val  set g-best-x p-best-x  set g-best-y p-best-y ] ]

  reset-ticks
end

; ----------------------------------------------------------
; POSICIÓN DE LA CÁMARA
; ----------------------------------------------------------
to set-observer-position
  ifelse random-search-space
  [ ask patches with [pzcor = max-pzcor] [ set pcolor 102 ]
    setxyz -40 -40 -50
    facexyz 0 0 10
    orbit-down 100 ]
  [ setxyz 50 50 50
    facexyz 0 0 10 ]
end

; ----------------------------------------------------------
; PAISAJE ALEATORIO (modo maximización)
; ----------------------------------------------------------
to create-random-search-space
  ask n-of hills-number patches with [pzcor = 0] [ set elevation 50 + random 100 ]
  repeat landscape-smoothness [ diffuse elevation 1 ]
  ask max-one-of patches [elevation] [ set true-best-patch self ]
end

; ----------------------------------------------------------
; FITNESS EN LA POSICIÓN ACTUAL DE UNA PARTÍCULA
; ----------------------------------------------------------
to-report get-elevation
  ifelse random-search-space
  [ report [elevation] of (patch (int xcor) (int ycor) 0) ]
  [ report objective-function xcor ycor ]
end

; ----------------------------------------------------------
; MALLA / SUPERFICIE 3D
; ----------------------------------------------------------
to draw-search-space
  let max-elev max [elevation] of patches
  ask patches with [pzcor = 0] [
    sprout-points 1 [ create-links-with points-on neighbors  hide-turtle ]
  ]
  ask points [ set zcor (elevation / max-elev) * max-pzcor ]
end

; ----------------------------------------------------------
; INICIALIZACIÓN DE PARTÍCULAS
; ----------------------------------------------------------
to initialize-particles
  create-particles population-size [
    setxy random-xcor random-ycor

    set p-best-x xcor
    set p-best-y ycor

    let z-elev get-elevation
    let max-elev max [elevation] of patches
    set zcor (z-elev / max-elev) * max-pzcor
    set p-best-val z-elev

    ;; Velocidad inicial de lengua pequeña y aleatoria
    set vx random-normal 0 0.5
    set vy random-normal 0 0.5

    set color red
    set shape "dot"
    set size 2
  ]
end

; ----------------------------------------------------------
; ACTUALIZACIÓN DE MEJORES (personal y global)
; ----------------------------------------------------------
to update-personal-global-best
  ask particles [
    let f get-elevation
    if (random-search-space and f > p-best-val)
       or ((not random-search-space) and f < p-best-val)
    [ set p-best-val f  set p-best-x xcor  set p-best-y ycor ]
  ]

  ifelse random-search-space
  [ ask max-one-of particles [p-best-val]
    [ if p-best-val > g-best-val
      [ set g-best-val p-best-val  set g-best-x p-best-x  set g-best-y p-best-y ] ] ]
  [ ask min-one-of particles [p-best-val]
    [ if p-best-val < g-best-val
      [ set g-best-val p-best-val  set g-best-x p-best-x  set g-best-y p-best-y ] ] ]
end

; ==========================================================
; BUCLE PRINCIPAL — CSA
;
; Mapeo de sliders a parámetros CSA:
;   Pp                          → probabilidad de exploración (Fase 1)
;   mu-max / mu-min             → rango del paso adaptativo μ(t)
;   max-iterations              → iteraciones para el decaimiento de μ
;   particle-inertia            → amortiguación de velocidad de lengua (Fase 3)
;   attraction-to-personal-best → ganancia hacia Pi (Fases 1 y 3)
;   attraction-to-global-best   → ganancia hacia G  (Fase 3)
;   particle-speed-limit        → límite de velocidad de lengua
; ==========================================================
to go

  ;; 1) Actualizar mejores con posiciones actuales
  update-personal-global-best

  ;; 2) μ(t): decaimiento lineal exploración → explotación
  ;;    Usa max-iterations como horizonte de decaimiento
  let tau (ticks / max-iterations)
  if tau > 1 [ set tau 1 ]
  let mu (mu-max - (mu-max - mu-min) * tau)

  ;; 3) CSA por partícula: Percepción → Rotación → Caza
  ask particles [

    ifelse trace-mode [ pen-down ] [ pen-up ]

    ;; ── Fase 1: Percepción / Búsqueda de presa ───────────────
    ;; Con prob. Pp → exploración aleatoria modulada por μ(t)
    ;; Con prob. 1-Pp → paso normalizado hacia Pi o G (50/50)
    ifelse (random-float 1.0 < Pp)
    [
      ;; Exploración: vector uniforme en [-1,1] × μ
      let rx (random-float 2 - 1)
      let ry (random-float 2 - 1)
      setxy (xcor + mu * attraction-to-personal-best * rx)
            (ycor + mu * attraction-to-personal-best * ry)
    ]
    [
      ifelse (random-float 1.0 < 0.5)
      [ ;; Movimiento normalizado hacia mejor personal (Pi)
        let dxp (p-best-x - xcor)
        let dyp (p-best-y - ycor)
        let dp sqrt (dxp * dxp + dyp * dyp)
        if dp > 0 [
          setxy (xcor + mu * attraction-to-personal-best * dxp / dp)
                (ycor + mu * attraction-to-personal-best * dyp / dp)
        ]
      ]
      [ ;; Movimiento normalizado hacia mejor global (G)
        let dxg (g-best-x - xcor)
        let dyg (g-best-y - ycor)
        let dg sqrt (dxg * dxg + dyg * dyg)
        if dg > 0 [
          setxy (xcor + mu * attraction-to-personal-best * dxg / dg)
                (ycor + mu * attraction-to-personal-best * dyg / dg)
        ]
      ]
    ]

    ;; ── Fase 2: Rotación ocular (visión 360°) ────────────────
    ;; Incondicional — todos los agentes en cada tick
    ;; heading + forward da giro suave y direccional
    let theta ((random-float (2 * pi)) - pi)
    let eye-step (mu * 0.5 * (0.5 + random-float 0.5))
    set heading (heading + theta * (180 / pi))
    forward eye-step

    ;; ── Fase 3: Caza / Proyección de la lengua ───────────────
    ;; Velocidad acumulada con amortiguación (momentum)
    ;; Atrae simultáneamente a Pi (r1) y G (r2) con pesos aleatorios
    ;; independientes → doble atracción + inercia = convergencia
    let r1 random-float 1.0
    let r2 random-float 1.0
    let ax (attraction-to-global-best * (r1 * (p-best-x - xcor) + r2 * (g-best-x - xcor)) / 2)
    let ay (attraction-to-global-best * (r1 * (p-best-y - ycor) + r2 * (g-best-y - ycor)) / 2)

    set vx (particle-inertia * vx + ax)
    set vy (particle-inertia * vy + ay)

    ;; Limitar velocidad de lengua
    if (vx >  particle-speed-limit) [ set vx  particle-speed-limit ]
    if (vx < (0 - particle-speed-limit)) [ set vx (0 - particle-speed-limit) ]
    if (vy >  particle-speed-limit) [ set vy  particle-speed-limit ]
    if (vy < (0 - particle-speed-limit)) [ set vy (0 - particle-speed-limit) ]

    ;; Aplicar proyección de lengua
    setxy (xcor + vx) (ycor + vy)

    ;; ── Corrección de límites ─────────────────────────────────
    if xcor > max-pxcor [ set xcor max-pxcor ]
    if xcor < min-pxcor [ set xcor min-pxcor ]
    if ycor > max-pycor [ set ycor max-pycor ]
    if ycor < min-pycor [ set ycor min-pycor ]

    ;; ── Actualizar altura 3D para visualización ───────────────
    let z-elev get-elevation
    let max-elev max [elevation] of patches
    set zcor (z-elev / max-elev) * max-pzcor
  ]

  if not trace-mode [ clear-drawing ]
  tick
end]]></code>
  <widgets>
    <view3d wrappingAllowedZ="true" x="0" wrappingAllowedX="true" y="0" minPycor="-20" height="255" showTickCounter="true" patchSize="6.0" fontSize="10" wrappingAllowedY="true" width="254" tickCounterLabel="ticks" maxPycor="20" updateMode="1" frameRate="30.0" maxPzcor="20" maxPxcor="20" minPxcor="-20" minPzcor="0"></view3d>
    <button x="241" y="65" height="47" disableUntilTicks="false" forever="false" kind="Observer" width="102" sizeVersion="0">setup</button>
