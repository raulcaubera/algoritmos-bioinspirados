[plot (1 / (mean [p-best-val] of particles))]
[plot mean [p-best-val] of particles]</update>
      </pen>
      <pen interval="1.0" mode="0" display="mejor" color="-2674135" legend="true">
        <setup></setup>
        <update>ifelse random-search-space
[plot (1 / (max [p-best-val] of particles))]
[plot min [p-best-val] of particles]</update>
      </pen>
      <pen interval="1.0" mode="0" display="peor" color="-13791810" legend="true">
        <setup></setup>
        <update>ifelse random-search-space
[plot (1 / (min [p-best-val] of particles))]
[plot max [p-best-val] of particles]</update>
      </pen>
    </plot>
    <slider x="380" step="10" y="74" max="1000" display="max-iterations" height="33" min="10" direction="Horizontal" default="100.0" variable="max-iterations" width="174" sizeVersion="0"></slider>
    <slider x="382" step="0.01" y="141" max="0.15" display="csa-Pp" height="33" min="0.0" direction="Horizontal" default="0.1" variable="csa-Pp" width="174" sizeVersion="0"></slider>
    <slider x="382" step="0.1" y="305" max="5" display="csa-beta" height="33" min="0.5" direction="Horizontal" default="3.0" variable="csa-beta" width="174" sizeVersion="0"></slider>
    <slider x="382" step="0.1" y="264" max="5" display="csa-alpha" height="33" min="0.5" direction="Horizontal" default="3.5" variable="csa-alpha" width="174" sizeVersion="0"></slider>
    <slider x="382" step="0.05" y="223" max="2" display="csa-p2" height="33" min="0.0" direction="Horizontal" default="1.5" variable="csa-p2" width="174" sizeVersion="0"></slider>
    <slider x="382" step="0.05" y="181" max="2" display="csa-p1" height="33" min="0.0" direction="Horizontal" default="0.25" variable="csa-p1" width="174" sizeVersion="0"></slider>
