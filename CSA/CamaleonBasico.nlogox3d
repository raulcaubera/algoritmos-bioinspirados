<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 3D 7.0.3" snapToGrid="false">
  <code><![CDATA[; ==========================================================
;  CSA — Algoritmo de Enjambre de Camaleones (NetLogo 3D)
; ==========================================================

breed [ points point ]       ;; puntos para visualizar la superficie (malla 3D)
breed [ particles particle ] ;; agentes camaleones que exploran el espacio

globals [
  g-best-vars
  g-best-val
  true-best-patch

  number-of-groups
  lower-bounds
  upper-bounds

  ;; parámetros CSA
  csa-c1
  csa-c2
  csa-gamma
  
]

particles-own [
  vars
  vel
  p-best-vars 
  p-best-val
  current-val
]

patches-own [
  elevation         ;; fitness del parche (visualización / paisaje aleatorio)
]




; ----------------------------------------------------------
; FUNCIÓN OBJETIVO: ESFERA  f(x,y) = x² + y²  (minimizar)
; ----------------------------------------------------------
to-report objective-function [x y]
  report (x ^ 2 + y ^ 2)
end



; ----------------------------------------------------------
; SETUP
; ----------------------------------------------------------
to setup
  clear-all
  setup-design-space
  ask patches [ set elevation 0 ]

  ifelse random-search-space
  [ create-random-search-space ]
  [ ask patches with [pzcor = 0] [ set elevation (objective-function pxcor pycor) ] ]

  draw-search-space
  initialize-particles
  set-observer-position

  ;; Inicializar mejor global coherente con el modo de optimización
  if random-search-space [
    let best one-of max-n-of 1 particles [p-best-val]
    set g-best-vars [p-best-vars] of best
    set g-best-val [p-best-val] of best 
  ]

  if not random-search-space [
    let best min-one-of particles [p-best-val]
    set g-best-vars [p-best-vars] of best
    set g-best-val [p-best-val] of best
  ]
  
  reset-ticks
end


to setup-design-space
  set number-of-groups 2

  ;; dominio del plano
  set lower-bounds (list min-pxcor min-pycor)
  set upper-bounds (list max-pxcor max-pycor)

  ;; parámetros CSA internos fijos
  ;; Los parámetros csa-Pp, csa-p1, csa-p2, csa-alpha y csa-beta
  ;; se leen desde sliders de la interfaz.
  set csa-c1 1.75
  set csa-c2 1.75
  set csa-gamma 1.0
end

; ----------------------------------------------------------
; POSICIÓN DE LA CÁMARA
; ----------------------------------------------------------
to set-observer-position
  ifelse random-search-space
  [ ask patches with [pzcor = max-pzcor] [ set pcolor 102 ]
    setxyz -40 -40 -50
    facexyz 0 0 10
    orbit-down 100 ]
  [ setxyz 50 50 50
    facexyz 0 0 10 ]
end

; ----------------------------------------------------------
; PAISAJE ALEATORIO (modo maximización)
; ----------------------------------------------------------
to create-random-search-space
  ask n-of hills-number patches with [pzcor = 0] [ set elevation 50 + random 100 ]
  repeat landscape-smoothness [ diffuse elevation 1 ]
  ask max-one-of patches [elevation] [ set true-best-patch self ]
end

; ----------------------------------------------------------
; FITNESS EN LA POSICIÓN ACTUAL DE UNA PARTÍCULA
; ----------------------------------------------------------
to-report get-elevation
  ifelse random-search-space
  [ report [elevation] of (patch (int xcor) (int ycor) 0) ]
  [ report objective-function xcor ycor ]
end

;; Evalúa un diseño [x y].
;; En modo esfera minimiza x^2 + y^2.
;; En modo paisaje aleatorio maximiza elevation.
to-report evaluate-design [design]
  let x item 0 design
  let y item 1 design

  if random-search-space [
    let px int x
    let py int y
    report [elevation] of patch px py 0
  ]

  report objective-function x y
end


;; Devuelve true si a es mejor que b.
;; En paisaje aleatorio se maximiza.
;; En esfera se minimiza.
to-report better-than? [a b]
  ifelse random-search-space
  [ report a > b ]
  [ report a < b ]
end


;; Copia segura de un diseño [x y].
to-report copy-design [design]
  if (not is-list? design) or (length design != 2) [
    report []
  ]

  report (list (item 0 design) (item 1 design))
end

to-report valid-design-list? [x]
  if not is-list? x [ report false ]
  if length x != number-of-groups [ report false ]
  report true
end

to-report vec-add [a b]
  report (map [[x y] -> x + y] a b)
end

to-report vec-sub [a b]
  report (map [[x y] -> x - y] a b)
end

to-report vec-clip [a low high]
  report (map [[x lo hi] -> max list lo (min list x hi)] a low high)
end

;; Sincroniza vars = [x y] con la posición visible 3D de la partícula.
to sync-particle-visual-state
  setxy (item 0 vars) (item 1 vars)

  let z-elev evaluate-design vars
  let max-elev max [elevation] of patches

  if max-elev = 0 [
    set max-elev 1
  ]

  set zcor (z-elev / max-elev) * max-pzcor
end

; ----------------------------------------------------------
; MALLA / SUPERFICIE 3D
; ----------------------------------------------------------
to draw-search-space
  let max-elev max [elevation] of patches
  ask patches with [pzcor = 0] [
    sprout-points 1 [ create-links-with points-on neighbors  hide-turtle ]
  ]
  ask points [ set zcor (elevation / max-elev) * max-pzcor ]
end

; ----------------------------------------------------------
; INICIALIZACIÓN DE PARTÍCULAS
; ----------------------------------------------------------
to initialize-particles
  create-particles population-size [

    ;; diseño inicial = [x y]
    set vars (list random-xcor random-ycor)

    ;; velocidad inicial = [vx vy]
    set vel (list
      ((random-float 1.0) - 0.5)
      ((random-float 1.0) - 0.5)
    )

    ;; fitness inicial
    set current-val evaluate-design vars

    ;; mejor personal inicial = estado inicial
    set p-best-vars copy-design vars
    set p-best-val current-val

    ;; posición visual 3D
    sync-particle-visual-state

    set color red
    set shape "dot"
    set size 2
  ]
end

; ----------------------------------------------------------
; ACTUALIZACIÓN DE MEJORES (personal y global)
; ----------------------------------------------------------
to update-personal-global-best
  ask particles [
    let f evaluate-design vars
    set current-val f

    if better-than? current-val p-best-val [
      set p-best-val current-val
      set p-best-vars copy-design vars
    ]
  ]

  if any? particles [
    let best-particle nobody

    ifelse random-search-space
    [ set best-particle max-one-of particles [p-best-val] ]
    [ set best-particle min-one-of particles [p-best-val] ]

    set g-best-vars copy-design ([p-best-vars] of best-particle)
    set g-best-val [p-best-val] of best-particle
  ]
end

to-report mu-paper [iter-num max-iter]
  let ratio (iter-num / max-iter)
  report (csa-gamma * exp ( - ((csa-alpha * ratio) ^ csa-beta) ))
end

to-report omega-paper [iter-num max-iter]
  report (1 - (iter-num / max-iter))
end

to-report accel-paper [iter-num]
  let a (2590 * (1 - (1 / (iter-num + 1))))
  if a < 1 [
    set a 1
  ]
  report a
end

to-report csa-search-step [x pbest gbest iter-num max-iter]
  if not valid-design-list? x [
    report (list random-xcor random-ycor)
  ]

  if not valid-design-list? pbest [
    set pbest copy-design x
  ]

  if not valid-design-list? gbest [
    set gbest copy-design pbest
  ]

  let mu mu-paper iter-num max-iter
  let result []
  let j 0

  while [j < length x] [
    let xj item j x
    let pj item j pbest
    let gj item j gbest
    let lj item j lower-bounds
    let uj item j upper-bounds

    let r1 random-float 1.0
    let r2 random-float 1.0
    let r3 random-float 1.0
    let ri random-float 1.0

    let sign-dir 1
    if random-float 1.0 < 0.5 [
      set sign-dir -1
    ]

    let new-xj xj

    ifelse ri >= csa-Pp
    [
      set new-xj (xj + (csa-p1 * (pj - gj) * r2) + (csa-p2 * (gj - xj) * r1))
    ]
    [
      set new-xj (xj + mu * (uj - lj) * r3 * sign-dir)
    ]

    if new-xj < lj [ set new-xj lj ]
    if new-xj > uj [ set new-xj uj ]

    set result lput new-xj result
    set j j + 1
  ]

  report result
end

to-report csa-eye-rotation-step [x-old x-search]
  let d length x-old
  if d < 2 [
    report x-search
  ]

  let i random d
  let j random d

  while [j = i] [
    set j random d
  ]

  let r random-float 1.0
  let sign-dir 1

  if random-float 1.0 < 0.5 [
    set sign-dir -1
  ]

  let theta (r * sign-dir * 180)

  let yc vec-sub x-search x-old

  let yi item i yc
  let yj item j yc

  let new-yi ((yi * cos theta) - (yj * sin theta))
  let new-yj ((yi * sin theta) + (yj * cos theta))

  let yc-rot replace-item i yc new-yi
  set yc-rot replace-item j yc-rot new-yj

  let rotated vec-add x-old yc-rot

  report vec-clip rotated lower-bounds upper-bounds
end

to-report csa-tongue-step [x-current pbest gbest old-vel iter-num max-iter]
  let omega omega-paper iter-num max-iter
  let a accel-paper iter-num

  let new-pos []
  let new-vel []

  let j 0
  while [j < length x-current] [
    let xj item j x-current
    let pj item j pbest
    let gj item j gbest
    let v-old item j old-vel

    let r1 random-float 1.0
    let r2 random-float 1.0

    let v-new ((omega * v-old) +
               (csa-c1 * (gj - xj) * r1) +
               (csa-c2 * (pj - xj) * r2))

    let x-new (xj + (((v-new * v-new) - (v-old * v-old)) / (2 * a)))

    let lj item j lower-bounds
    let uj item j upper-bounds

    if x-new < lj [ set x-new lj ]
    if x-new > uj [ set x-new uj ]

    set new-pos lput x-new new-pos
    set new-vel lput v-new new-vel

    set j j + 1
  ]

  report (list new-pos new-vel)
end

to csa-greedy-move [candidate-vars candidate-val candidate-vel]
  if better-than? candidate-val current-val [
    set vars copy-design candidate-vars
    set current-val candidate-val
    set vel candidate-vel
  ]
end


; ==========================================================
; BUCLE PRINCIPAL — CSA PAPER-FAITHFUL
;
; Parámetros principales:
;   csa-Pp          → probabilidad de usar la rama guiada/exploratoria
;   csa-p1          → peso asociado al mejor personal en la fase de búsqueda
;   csa-p2          → peso asociado al mejor global en la fase de búsqueda
;   csa-alpha       → controla el decaimiento de μ(t)
;   csa-beta        → controla el decaimiento de μ(t)
;   max-iterations  → horizonte temporal del algoritmo
;
; El motor usa representación vectorial:
;   vars = [x y]
;   vel  = [vx vy]
; ==========================================================
to go
  if ticks >= max-iterations [
    stop
  ]

  update-personal-global-best

  let iter-num (ticks + 1)
  let max-iter max-iterations

  ask particles [

    ifelse trace-mode
    [ pen-down ]
    [ pen-up ]

    if not valid-design-list? p-best-vars [
      set p-best-vars copy-design vars
      set p-best-val current-val
    ]

    let x0 copy-design vars
    let old-vel vel

    ;; Paso 1: búsqueda / percepción
    let x1 csa-search-step x0 p-best-vars g-best-vars iter-num max-iter
    let f1 evaluate-design x1
    csa-greedy-move x1 f1 old-vel

    let x-after-search vars

    ;; Paso 2: rotación ocular
    let x2 csa-eye-rotation-step x0 x-after-search
    let f2 evaluate-design x2
    csa-greedy-move x2 f2 old-vel

    let x-after-eye vars

    ;; Paso 3: lengua
    let tongue-output csa-tongue-step x-after-eye p-best-vars g-best-vars old-vel iter-num max-iter
    let x3 item 0 tongue-output
    let v3 item 1 tongue-output
    let f3 evaluate-design x3
    csa-greedy-move x3 f3 v3

    ;; actualizar posición visible 3D
    sync-particle-visual-state
  ]

  update-personal-global-best

  if not trace-mode [
    clear-drawing
  ]

  tick
end






;; funcion de prueba y experimentacion
to-report experimento [n semilla]
  set random-search-space false
  set trace-mode false
  random-seed semilla

  setup

  set max-iterations n

  repeat n [
    go
  ]

  report (list
    "algoritmo" "CSA"
    "population-size" population-size
    "seed" semilla
    "ticks" ticks
    "best-x" item 0 g-best-vars
    "best-y" item 1 g-best-vars
    "best-val" g-best-val
    "mean-val" mean [current-val] of particles
  )
end

to exportar-lote [poblaciones iteraciones semillas fichero]
  if file-exists? fichero [
    file-delete fichero
  ]

  file-open fichero

  ;; Cabecera del CSV
  file-print "algoritmo,population_size,seed,ticks,best_x,best_y,best_val,mean_val"

  foreach poblaciones [ p ->
    set population-size p

    foreach iteraciones [ n ->
      foreach semillas [ s ->

        ;; Ejecutar experimento
        let resultado experimento n s

        ;; Guardar fila en CSV usando el estado final del modelo
        file-print (word
          "CSA" ","
          population-size ","
          s ","
          ticks ","
          item 0 g-best-vars ","
          item 1 g-best-vars ","
          g-best-val ","
          mean [current-val] of particles
        )

        ;; Mostrar también por consola para seguir el lote
        show resultado
      ]
    ]
  ]

  file-close

  show (word "Lote terminado. Archivo guardado en: " fichero)
end


to lote-csa-basico
  exportar-lote [50 100 200] [10 50 100] [1 2 3 4 5] "resultados_csa.csv"
end



]]></code>
  <widgets>
    <view3d wrappingAllowedZ="true" x="0" wrappingAllowedX="true" y="0" minPycor="-20" height="255" showTickCounter="true" patchSize="6.0" fontSize="10" wrappingAllowedY="true" width="254" tickCounterLabel="ticks" maxPycor="20" updateMode="1" frameRate="30.0" maxPzcor="20" maxPxcor="20" minPxcor="-20" minPzcor="0"></view3d>
    <button x="241" y="65" height="47" disableUntilTicks="false" forever="false" kind="Observer" display="SETUP CSA" width="102" sizeVersion="0">setup</button>
    <button x="240" y="174" height="44" disableUntilTicks="false" forever="true" kind="Observer" display="EJECUTAR CSA" width="117" sizeVersion="0">go</button>
    <button x="241" y="120" height="46" disableUntilTicks="false" forever="false" kind="Observer" display="STEP by STEP" width="102" sizeVersion="0">go</button>
