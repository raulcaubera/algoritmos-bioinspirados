end

to check-120bar-benchmark-consistency
  show "=============================================="
  show "CHECK CONSISTENCIA BENCHMARK 120-BAR"
  show "=============================================="

  ifelse (length node-coords = 49)
    [ show "OK: numero de nodos = 49" ]
    [ show (word "ERROR: nodos = " length node-coords " (esperado 49)") ]

  ifelse (length member-connectivity = 120)
    [ show "OK: numero de barras = 120" ]
    [ show (word "ERROR: barras = " length member-connectivity " (esperado 120)") ]

  ifelse (member-group-counts = [12 12 12 24 24 12 24])
    [ show "OK: grupos = [12 12 12 24 24 12 24]" ]
    [ show (word "ERROR: grupos = " member-group-counts) ]

  ifelse (length support-node-ids = 12)
    [ show "OK: nodos apoyados = 12" ]
    [ show (word "ERROR: apoyos = " length support-node-ids " (esperado 12)") ]

  ifelse (total-dofs = 147)
    [ show "OK: dofs totales = 147" ]
    [ show (word "ERROR: dofs totales = " total-dofs " (esperado 147)") ]

  ifelse (length free-dofs = 111)
    [ show "OK: dofs libres = 111" ]
    [ show (word "ERROR: dofs libres = " length free-dofs " (esperado 111)") ]

  show "=============================================="
end

