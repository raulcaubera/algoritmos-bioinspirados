<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 3D 7.0.3" snapToGrid="false">
  <code><![CDATA[; ==========================================================
;  CSA — Algoritmo de Enjambre de Camaleones
;  Versión refactorizada para diseño estructural vectorial
;  (preparada para el domo de 120 barras, 7 variables)
; ==========================================================

breed [ particles particle ]

globals [
  g-best-vars         ;; mejor solución global (lista)
  g-best-val          ;; mejor fitness global

  number-of-groups    ;; número de variables de diseño
  lower-bounds        ;; lista de límites inferiores
  upper-bounds        ;; lista de límites superiores
  
  ;; parámetros base del benchmark
  base-young-modulus
  base-density
  base-frequency-1
  base-frequency-2

  ;; parámetros efectivos (modificados por sliders)
  effective-young-modulus
  effective-density
  min-frequency-1
  min-frequency-2

  ;; masas nodales no estructurales efectivas
  apex-extra-mass
  upper-ring-extra-mass
  mid-ring-extra-mass
  
  
  ;; --- modelo del domo de 120 barras ---
  node-coords
  member-connectivity
  member-lengths

  support-node-ids
  total-dofs
  restrained-dofs
  free-dofs

  member-group-counts

  apex-node-id
  upper-ring-node-ids
  mid-ring-node-ids
  outer-ring-node-ids

  ;; parámetros CSA paper-faithful
  csa-c1
  csa-c2
  csa-gamma
  
  ;; penalización estática para el domo
  penalty-lambda
  
  ;; métricas cacheadas para la interfaz
  ui-best-weight
  ui-best-f1
  ui-best-f2
  ui-best-violation
  ui-best-feasible
  ui-best-margin-f1
  ui-best-margin-f2
  
  model-ready?

]

particles-own [
  vars                ;; solución actual de la partícula: lista de variables
  vel                 ;; velocidad vectorial
  p-best-vars         ;; mejor solución personal
  p-best-val          ;; mejor fitness personal
  current-val         ;; fitness actual
  current-weight      ;; peso actual
]



; ==========================================================
; SETUP E INICIALIZACION
; Construccion del problema, inicializacion de particulas
; y siembra del mejor diseño global inicial.
; ==========================================================


;; Inicializa el modelo completo: limpia el estado previo, 
;; configura el problema, construye el domo, crea las partículas 
to setup
  clear-all

  set model-ready? false
  set g-best-vars []
  set g-best-val 1.0E+20

  setup-design-space
  build-120bar-model
  initialize-particles
  seed-global-best
  update-personal-global-best
  update-ui-metrics

  reset-ticks
  set model-ready? true
end


;; Calcula el mejor diseño global inicial a partir del mejor valor actual
;; de las partículas recién inicializadas.
to seed-global-best
  if not any? particles [
    set g-best-vars []
    set g-best-val 1.0E+20
    stop
  ]

  let best-particle min-one-of particles [current-val]
  let best-design [vars] of best-particle

  if (is-list? best-design) and (length best-design = number-of-groups) [
    set g-best-vars (list
      (item 0 best-design)
      (item 1 best-design)
      (item 2 best-design)
      (item 3 best-design)
      (item 4 best-design)
      (item 5 best-design)
      (item 6 best-design)
    )
  ]

  set g-best-val [current-val] of best-particle
end


; ESPACIO DE DISEÑO DEL PROBLEMA


;; Configura el dominio del problema:
;; - limites de las 7 variables de diseño
;; - propiedades fisicas efectivas
;; - masas nodales no estructurales
;; - constantes fijas del CSA y penalizacion (c1 y c2: coeficientes de la fase de lengua; alpha y beta: controlan la forma de μ(t))
to setup-design-space
  ;; 7 grupos del domo de 120 barras
  set number-of-groups 7

  ;; áreas continuas entre 1 y 129.3 cm^2
  set lower-bounds n-values number-of-groups [ -> 1.0 ]
  set upper-bounds n-values number-of-groups [ -> 129.3 ]

  ;; datos base del benchmark
  set base-young-modulus 210e9
  set base-density 7971.810
  set base-frequency-1 9
  set base-frequency-2 11

  ;; aplicar sliders de sensibilidad
  set effective-young-modulus (base-young-modulus * young-modulus-factor)
  set effective-density (base-density * density-factor)

  set min-frequency-1 (base-frequency-1 * frequency-target-factor)
  set min-frequency-2 (base-frequency-2 * frequency-target-factor)

  ;; masas no estructurales efectivas
  ;; benchmark base: 3000 kg, 500 kg, 100 kg
  set apex-extra-mass       (3000 * nonstructural-mass-factor)
  set upper-ring-extra-mass (500  * nonstructural-mass-factor)
  set mid-ring-extra-mass   (100  * nonstructural-mass-factor)

  ;; ==========================================
  ;; CSA paper-faithful (ingeniería)
  ;; ==========================================
  set csa-c1 1.75
  set csa-c2 1.75
  set csa-gamma 1.0
  set penalty-lambda 100000
  
end


;; Genera un diseño aleatorio uniforme dentro de los limites del problema.
to-report random-design
  report random-vector-between lower-bounds upper-bounds
end



;; Crea la población inicial de partículas.
;; Cada partícula comienza con un diseño aleatorio,
;; velocidad nula y mejor personal igual a su estado inicial.
to initialize-particles
  create-particles population-size [
    set vars random-design
    set vel zero-vector number-of-groups
    
    set current-weight compute-real-weight vars
    set current-val evaluate-design-120-accurate vars
    set p-best-vars copy-design vars
    set p-best-val current-val

    hide-turtle
  ]
end



;; Actualiza los mejores personales de las partículas y
;; recalcula el mejor diseño global del enjambre.
to update-personal-global-best
  ask particles [
    if current-val < p-best-val [
      set p-best-val current-val
      set p-best-vars copy-design vars
    ]
  ]

  if any? particles [
    let best-particle min-one-of particles [p-best-val]
    let best-design [p-best-vars] of best-particle

    if (is-list? best-design) and (length best-design = 7) [
      set g-best-vars (list
        (item 0 best-design)
        (item 1 best-design)
        (item 2 best-design)
        (item 3 best-design)
        (item 4 best-design)
        (item 5 best-design)
        (item 6 best-design)
      )
    ]

    set g-best-val [p-best-val] of best-particle
  ]
end



; ==========================================================
; EVALUACION Y FITNESS
; Funciones que calculan peso, frecuencias y fitness penalizado.
; ==========================================================



;; Calcula las dos primeras frecuencias usando una evaluacion rapida
;; con menos iteraciones de Jacobi para filtrar candidatos
to-report first-two-natural-frequencies-fast [design]
  report first-two-natural-frequencies-with-rotations design 3000
end


;; Calcula las dos primeras frecuencias naturales con la precision
;; seleccionada en la interfaz mediante el chooser accurate-rotations.
to-report first-two-natural-frequencies-accurate [design]
  report first-two-natural-frequencies-with-rotations design accurate-rotations
end


;; Evalua rapidamente un diseño:
;; peso real + penalizacion por violacion de frecuencias.
to-report evaluate-design-120-fast [design]
  let weight compute-real-weight design
  let freqs first-two-natural-frequencies-fast design

  let frequency-1 item 0 freqs
  let frequency-2 item 1 freqs

  let v1 max list 0 ((min-frequency-1 - frequency-1) / min-frequency-1)
  let v2 max list 0 ((min-frequency-2 - frequency-2) / min-frequency-2)

  let penalty (penalty-lambda * (v1 + v2))

  report weight + penalty
end

;; Evalua de forma precisa un diseño:
;; peso real + penalizacion por violacion de frecuencias.
to-report evaluate-design-120-accurate [design]
  let weight compute-real-weight design
  let freqs first-two-natural-frequencies-accurate design

  let frequency-1 item 0 freqs
  let frequency-2 item 1 freqs

  let v1 max list 0 ((min-frequency-1 - frequency-1) / min-frequency-1)
  let v2 max list 0 ((min-frequency-2 - frequency-2) / min-frequency-2)

  let penalty (penalty-lambda * (v1 + v2))

  report weight + penalty
end


;; Reporter general del fitness usado por el CSA durante la busqueda.
;; En esta implementacion devuelve la evaluacion rapida.
to-report evaluate-design [design]
  report evaluate-design-120-fast design
end

;; Devuelve la matriz de masa consistente elemental de una barra 3D.
to-report element-consistent-mass-3d [area node-i node-j]
  let elem-length distance-between-nodes node-i node-j
  let coeff (effective-density * area * elem-length / 6)

  report (list
    (list (2 * coeff) 0 0 coeff 0 0)
    (list 0 (2 * coeff) 0 0 coeff 0)
    (list 0 0 (2 * coeff) 0 0 coeff)

    (list coeff 0 0 (2 * coeff) 0 0)
    (list 0 coeff 0 0 (2 * coeff) 0)
    (list 0 0 coeff 0 0 (2 * coeff))
  )
end


; ==========================================================
; UTILIDADES VECTORIALES
; ==========================================================

;; Devuelve una copia explicita de un diseño de 7 variables.
;; Si el argumento no es un diseño valido, devuelve lista vacia.
to-report copy-design [design]
  if (not is-list? design) or (length design != 7) [
    report []
  ]

  report (list
    (item 0 design)
    (item 1 design)
    (item 2 design)
    (item 3 design)
    (item 4 design)
    (item 5 design)
    (item 6 design)
  )
end

;; Construye un vector de ceros de longitud n.
to-report zero-vector [n]
  report n-values n [ i -> 0 ]
end

;; Construye una matriz de ceros de tamaño rows x cols.
to-report zero-matrix [rows cols]
  report n-values rows [ r -> n-values cols [ c -> 0 ] ]
end

;; Devuelve una copia de la matriz con un valor reemplazado
;; en la posicion [row-index, col-index].
to-report matrix-set [mat row-index col-index new-value]
  let selected-row item row-index mat
  let updated-row replace-item col-index selected-row new-value
  report replace-item row-index mat updated-row
end

;; Suma un incremento a una posicion concreta de una matriz
;; y devuelve la matriz resultante.
to-report matrix-add [mat row-index col-index increment]
  let current-value item col-index (item row-index mat)
  report matrix-set mat row-index col-index (current-value + increment)
end

;; Suma componente a componente dos vectores.
to-report vec-add [a b]
  report (map [[x y] -> x + y] a b)
end

;; Resta componente a componente dos vectores.
to-report vec-sub [a b]
  report (map [[x y] -> x - y] a b)
end

;; Multiplica un vector por un escalar.
to-report vec-scale [s a]
  report (map [x -> s * x] a)
end

;; Calcula la norma euclidea de un vector.
to-report vec-norm [a]
  report sqrt (sum (map [x -> x * x] a))
end

;; Limita componente a componente un vector entre dos listas de cotas.
to-report vec-clip [a low high]
  report (map [[x lo hi] -> max list lo (min list x hi)] a low high)
end

;; Limita el valor absoluto de cada componente de un vector.
to-report vec-limit-components [a lim]
  report (map [x -> max list (- lim) (min list x lim)] a)
end

;; Genera un vector aleatorio uniforme entre dos listas de limites.
to-report random-vector-between [low high]
  report (map [[lo hi] -> lo + random-float (hi - lo)] low high)
end

;; Genera un vector de longitud n con componentes uniformes en [-1,1].
to-report random-uniform-vector [n]
  report n-values n [ -> (random-float 2 - 1) ]
end



; ==========================================================
; MODELO ESTRUCTURAL DEL DOMO DE 120 BARRAS
; Geometria, conectividad, ensamblaje FEM y calculo modal.
; Basado en el benchmark de 49 nodos / 120 barras / 7 grupos
; ==========================================================


;; Construye el modelo completo del domo:
;; nodos, conectividad, longitudes y grados de libertad.
to build-120bar-model
  ;; 49 nodos espaciales, 3 DOFs por nodo
  set total-dofs (49 * 3)

  ;; grupos del benchmark: 12, 12, 12, 24, 24, 12, 24 = 120
  set member-group-counts [12 12 12 24 24 12 24]

  ;; apoyos: anillo exterior
  set outer-ring-node-ids n-values 12 [i -> i + 1]
  set support-node-ids outer-ring-node-ids

  ;; nodos útiles para masas nodales posteriores
  set mid-ring-node-ids   n-values 24 [i -> i + 13]   ;; 13..36
  set upper-ring-node-ids n-values 12 [i -> i + 37]   ;; 37..48
  set apex-node-id 49

  build-120bar-node-coords
  build-120bar-connectivity
  build-120bar-member-lengths

  set restrained-dofs build-restrained-dofs
  set free-dofs build-free-dofs
end

;; Genera las coordenadas 3D de los 49 nodos del domo.
to build-120bar-node-coords
  set node-coords []

  ;; ----------------------------------------
  ;; Nodos 1..12  : anillo exterior
  ;; radio = 15.89 m, z = 0 m
  ;; 12 nodos -> incremento angular de 30 grados
  ;; ----------------------------------------
  let i 0
  while [i < 12] [
    let theta-deg (i * 30)
    let x (15.89 * cos theta-deg)
    let y (15.89 * sin theta-deg)
    let z 0
    set node-coords lput (list x y z) node-coords
    set i i + 1
  ]

  ;; ----------------------------------------
  ;; Nodos 13..36 : anillo intermedio
  ;; radio = 12.04 m, z = 3 m
  ;; 24 nodos -> incremento angular de 15 grados
  ;; ----------------------------------------
  set i 0
  while [i < 24] [
    let theta-deg (i * 15)
    let x (12.04 * cos theta-deg)
    let y (12.04 * sin theta-deg)
    let z 3
    set node-coords lput (list x y z) node-coords
    set i i + 1
  ]

  ;; ----------------------------------------
  ;; Nodos 37..48 : anillo superior
  ;; radio = 6.94 m, z = 5.85 m
  ;; 12 nodos -> incremento angular de 30 grados
  ;; ----------------------------------------
  set i 0
  while [i < 12] [
    let theta-deg (i * 30)
    let x (6.94 * cos theta-deg)
    let y (6.94 * sin theta-deg)
    let z 5.85
    set node-coords lput (list x y z) node-coords
    set i i + 1
  ]

  ;; ----------------------------------------
  ;; Nodo 49 : ápice
  ;; ----------------------------------------
  set node-coords lput (list 0 0 7.0) node-coords
end



;; Genera la conectividad de las 120 barras segun la agrupacion del benchmark.
to build-120bar-connectivity
  set member-connectivity []

  ;; ======================================================
  ;; GRUPO 1 (12 barras)
  ;; Ápice (49) conectado al anillo superior (37..48)
  ;; ======================================================
  let i 1
  while [i <= 12] [
    set member-connectivity lput (list 49 (49 - i)) member-connectivity
    set i i + 1
  ]

  ;; ======================================================
  ;; GRUPO 2 (12 barras)
  ;; Anillo superior circunferencial: 37-38-...-48-37
  ;; ======================================================
  set i 1
  while [i <= 11] [
    set member-connectivity lput (list (36 + i) (36 + i + 1)) member-connectivity
    set i i + 1
  ]
  set member-connectivity lput (list 48 37) member-connectivity

  ;; ======================================================
  ;; GRUPO 3 (12 barras)
  ;; Conexión anillo superior → anillo intermedio
  ;; patrón radial
  ;; ======================================================
  set i 1
  while [i <= 12] [
    set member-connectivity lput (list (36 + i) (2 * i + 11)) member-connectivity
    set i i + 1
  ]

  ;; ======================================================
  ;; GRUPO 4 (24 barras)
  ;; Diagonales entre anillo superior e intermedio
  ;; ======================================================
  set i 1
  while [i <= 11] [
    set member-connectivity lput (list (37 + i) (2 * i + 12)) member-connectivity
    set member-connectivity lput (list (37 + i) (2 * i + 14)) member-connectivity
    set i i + 1
  ]
  set member-connectivity lput (list 37 36) member-connectivity
  set member-connectivity lput (list 37 14) member-connectivity

  ;; ======================================================
  ;; GRUPO 5 (24 barras)
  ;; Anillo intermedio circunferencial: 13-14-...-36-13
  ;; ======================================================
  set i 1
  while [i <= 23] [
    set member-connectivity lput (list (12 + i) (12 + i + 1)) member-connectivity
    set i i + 1
  ]
  set member-connectivity lput (list 36 13) member-connectivity

  ;; ======================================================
  ;; GRUPO 6 (12 barras)
  ;; Conexión anillo intermedio → anillo exterior
  ;; patrón radial
  ;; ======================================================
  set i 1
  while [i <= 12] [
    set member-connectivity lput (list (11 + 2 * i) i) member-connectivity
    set i i + 1
  ]

  ;; ======================================================
  ;; GRUPO 7 (24 barras)
  ;; Diagonales entre anillo exterior e intermedio
  ;; ======================================================
  set i 2
  while [i <= 12] [
    set member-connectivity lput (list i (2 * i + 10)) member-connectivity
    set member-connectivity lput (list i (2 * i + 12)) member-connectivity
    set i i + 1
  ]
  set member-connectivity lput (list 1 14) member-connectivity
  set member-connectivity lput (list 1 36) member-connectivity
end

;; Calcula la longitud de cada barra a partir de la conectividad y las coordenadas.
to build-120bar-member-lengths
  set member-lengths []

  let i 0
  while [i < length member-connectivity] [
    let conn item i member-connectivity
    let ni first conn
    let nj last conn

    set member-lengths lput (distance-between-nodes ni nj) member-lengths
    set i i + 1
  ]
end

;; Devuelve las coordenadas [x y z] de un nodo dado su identificador.
to-report node-xyz [node-id]
  report item (node-id - 1) node-coords
end

;; Calcula la distancia euclidea entre dos nodos del domo.
to-report distance-between-nodes [ni nj]
  let p node-xyz ni
  let q node-xyz nj

  let delta-x ((item 0 q) - (item 0 p))
  let delta-y ((item 1 q) - (item 1 p))
  let delta-z ((item 2 q) - (item 2 p))

  report sqrt (delta-x * delta-x + delta-y * delta-y + delta-z * delta-z)
end

;; Devuelve los tres indices globales de grados de libertad de un nodo.
to-report node-dof-indices [node-id]
  let base (3 * (node-id - 1))
  report (list base (base + 1) (base + 2))
end


;; Construye la lista de grados de libertad restringidos
;; a partir de los nodos apoyados.
to-report build-restrained-dofs
  let result []
  let i 0

  while [i < length support-node-ids] [
    let node-id item i support-node-ids
    let dofs node-dof-indices node-id
    set result sentence result dofs
    set i i + 1
  ]

  report result
end


;; Construye la lista de grados de libertad libres
;; eliminando los restringidos del total.
to-report build-free-dofs
  let result []
  let d 0

  while [d < total-dofs] [
    if not member? d restrained-dofs [
      set result lput d result
    ]
    set d d + 1
  ]

  report result
end

;; Devuelve los seis grados de libertad de una barra 3D.
to-report element-dof-indices [node-i node-j]
  report sentence (node-dof-indices node-i) (node-dof-indices node-j)
end



;; Expande el diseño de 7 areas a las 120 barras reales
;; y convierte cm² a m².
to-report expand-design-to-members [design]
  ;; design = [A1 ... A7] en cm^2
  ;; salida = lista de 120 áreas en m^2

  let member-areas []
  let group-index 0

  while [group-index < length design] [
    let area-cm2 item group-index design
    let area-m2 (area-cm2 * 1.0e-4)

    let group-size item group-index member-group-counts
    let local-index 0

    while [local-index < group-size] [
      set member-areas lput area-m2 member-areas
      set local-index local-index + 1
    ]

    set group-index group-index + 1
  ]

  report member-areas
end



;; Extrae una submatriz de una matriz global
;; usando una lista de indices de fila y columna.
to-report submatrix-by-indices [full-matrix index-list]
  let result []
  let row-pos 0

  while [row-pos < length index-list] [
    let row-index item row-pos index-list
    let full-row item row-index full-matrix

    let reduced-row []
    let col-pos 0

    while [col-pos < length index-list] [
      let col-index item col-pos index-list
      set reduced-row lput (item col-index full-row) reduced-row
      set col-pos col-pos + 1
    ]

    set result lput reduced-row result
    set row-pos row-pos + 1
  ]

  report result
end

;; Devuelve la matriz de rigidez elemental 3D de una barra.
to-report element-stiffness-3d [area node-i node-j]
  let coord-i node-xyz node-i
  let coord-j node-xyz node-j

  let x1 item 0 coord-i
  let y1 item 1 coord-i
  let z1 item 2 coord-i

  let x2 item 0 coord-j
  let y2 item 1 coord-j
  let z2 item 2 coord-j

  let delta-x (x2 - x1)
  let delta-y (y2 - y1)
  let delta-z (z2 - z1)

  let elem-length sqrt (delta-x * delta-x + delta-y * delta-y + delta-z * delta-z)

  let dir-cx (delta-x / elem-length)
  let dir-cy (delta-y / elem-length)
  let dir-cz (delta-z / elem-length)

  let coeff (effective-young-modulus * area / elem-length)

  report (list
    (list (coeff * dir-cx * dir-cx) (coeff * dir-cx * dir-cy) (coeff * dir-cx * dir-cz)
          (- coeff * dir-cx * dir-cx) (- coeff * dir-cx * dir-cy) (- coeff * dir-cx * dir-cz))

    (list (coeff * dir-cx * dir-cy) (coeff * dir-cy * dir-cy) (coeff * dir-cy * dir-cz)
          (- coeff * dir-cx * dir-cy) (- coeff * dir-cy * dir-cy) (- coeff * dir-cy * dir-cz))

    (list (coeff * dir-cx * dir-cz) (coeff * dir-cy * dir-cz) (coeff * dir-cz * dir-cz)
          (- coeff * dir-cx * dir-cz) (- coeff * dir-cy * dir-cz) (- coeff * dir-cz * dir-cz))

    (list (- coeff * dir-cx * dir-cx) (- coeff * dir-cx * dir-cy) (- coeff * dir-cx * dir-cz)
          (coeff * dir-cx * dir-cx) (coeff * dir-cx * dir-cy) (coeff * dir-cx * dir-cz))

    (list (- coeff * dir-cx * dir-cy) (- coeff * dir-cy * dir-cy) (- coeff * dir-cy * dir-cz)
          (coeff * dir-cx * dir-cy) (coeff * dir-cy * dir-cy) (coeff * dir-cy * dir-cz))

    (list (- coeff * dir-cx * dir-cz) (- coeff * dir-cy * dir-cz) (- coeff * dir-cz * dir-cz)
          (coeff * dir-cx * dir-cz) (coeff * dir-cy * dir-cz) (coeff * dir-cz * dir-cz))
  )
end



;; Ensambla la matriz de rigidez global del domo
;; a partir del diseño actual.
to-report assemble-global-stiffness [design]
  let member-areas expand-design-to-members design
  let global-k zero-matrix total-dofs total-dofs

  let elem-index 0
  while [elem-index < length member-connectivity] [
    let elem-conn item elem-index member-connectivity
    let node-i first elem-conn
    let node-j last elem-conn

    let area item elem-index member-areas
    let elem-k element-stiffness-3d area node-i node-j
    let elem-dofs element-dof-indices node-i node-j

    let local-row 0
    while [local-row < 6] [
      let global-row item local-row elem-dofs

      let local-col 0
      while [local-col < 6] [
        let global-col item local-col elem-dofs
        let k-value item local-col (item local-row elem-k)

        set global-k matrix-add global-k global-row global-col k-value
        set local-col local-col + 1
      ]

      set local-row local-row + 1
    ]

    set elem-index elem-index + 1
  ]

  report global-k
end



;; Ensambla la matriz de masas global del domo:
;; incluye masa estructural y masas nodales no estructurales.
to-report assemble-global-mass [design]
  let member-areas expand-design-to-members design
  let global-m zero-matrix total-dofs total-dofs

  ;; ----------------------------------------
  ;; 1) masa estructural consistente de barras
  ;; ----------------------------------------
  let elem-index 0
  while [elem-index < length member-connectivity] [
    let elem-conn item elem-index member-connectivity
    let node-i first elem-conn
    let node-j last elem-conn

    let area-value item elem-index member-areas
    let elem-m element-consistent-mass-3d area-value node-i node-j
    let elem-dofs element-dof-indices node-i node-j

    let local-row 0
    while [local-row < 6] [
      let global-row item local-row elem-dofs

      let local-col 0
      while [local-col < 6] [
        let global-col item local-col elem-dofs
        let m-value item local-col (item local-row elem-m)

        set global-m matrix-add global-m global-row global-col m-value
        set local-col local-col + 1
      ]

      set local-row local-row + 1
    ]

    set elem-index elem-index + 1
  ]

  ;; ----------------------------------------
  ;; 2) masas no estructurales nodales
  ;; (se añaden en la diagonal de los DOFs traslacionales)
  ;; ----------------------------------------

  ;; ápice
  let apex-dofs node-dof-indices apex-node-id
  let ia 0
  while [ia < 3] [
    let dof-index item ia apex-dofs
    set global-m matrix-add global-m dof-index dof-index apex-extra-mass
    set ia ia + 1
  ]

  ;; anillo superior
  let ur-index 0
  while [ur-index < length upper-ring-node-ids] [
    let node-id item ur-index upper-ring-node-ids
    let dofs node-dof-indices node-id

    let k 0
    while [k < 3] [
      let dof-index item k dofs
      set global-m matrix-add global-m dof-index dof-index upper-ring-extra-mass
      set k k + 1
    ]

    set ur-index ur-index + 1
  ]

  ;; anillo intermedio
  let mr-index 0
  while [mr-index < length mid-ring-node-ids] [
    let node-id item mr-index mid-ring-node-ids
    let dofs node-dof-indices node-id

    let k 0
    while [k < 3] [
      let dof-index item k dofs
      set global-m matrix-add global-m dof-index dof-index mid-ring-extra-mass
      set k k + 1
    ]

    set mr-index mr-index + 1
  ]

  report global-m
end


;; Devuelve la traspuesta de una matriz.
to-report matrix-transpose [mat]
  let rows length mat
  let cols length first mat
  let result zero-matrix cols rows

  let row-index 0
  while [row-index < rows] [
    let col-index 0
    while [col-index < cols] [
      let val item col-index (item row-index mat)
      set result matrix-set result col-index row-index val
      set col-index col-index + 1
    ]
    set row-index row-index + 1
  ]

  report result
end

;; Calcula la descomposicion de Cholesky de una matriz simetrica definida positiva.
to-report cholesky-decomposition [mat]
  let n length mat
  let lower-tri zero-matrix n n

  let row-index 0
  while [row-index < n] [
    let col-index 0
    while [col-index <= row-index] [
      let sum-value 0
      let k 0
      while [k < col-index] [
        set sum-value sum-value +
          ((item k (item row-index lower-tri)) * (item k (item col-index lower-tri)))
        set k k + 1
      ]

      if row-index = col-index [
        let diag-value ((item col-index (item row-index mat)) - sum-value)
        if diag-value <= 0 [
          report nobody
        ]
        set lower-tri matrix-set lower-tri row-index col-index sqrt diag-value
      ]

      if row-index > col-index [
        let lij (((item col-index (item row-index mat)) - sum-value) /
                 (item col-index (item col-index lower-tri)))
        set lower-tri matrix-set lower-tri row-index col-index lij
      ]

      set col-index col-index + 1
    ]
    set row-index row-index + 1
  ]

  report lower-tri
end


;; Resuelve un sistema triangular inferior con varios terminos independientes.
to-report solve-lower-left [lower-mat rhs-mat]
  let n length lower-mat
  let ncols length first rhs-mat
  let solution-mat zero-matrix n ncols

  let col-index 0
  while [col-index < ncols] [
    let row-index 0
    while [row-index < n] [
      let rhs-value item col-index (item row-index rhs-mat)

      let k 0
      while [k < row-index] [
        set rhs-value rhs-value -
          ((item k (item row-index lower-mat)) * (item col-index (item k solution-mat)))
        set k k + 1
      ]

      let x-value (rhs-value / (item row-index (item row-index lower-mat)))
      set solution-mat matrix-set solution-mat row-index col-index x-value

      set row-index row-index + 1
    ]

    set col-index col-index + 1
  ]

  report solution-mat
end



;; Convierte el problema modal generalizado K phi = lambda M phi
;; en un problema estandar usando Cholesky.
to-report generalized-to-standard-matrix-full [reduced-k reduced-m]
  let lower-chol cholesky-decomposition reduced-m

  if lower-chol = nobody [
    report nobody
  ]

  ;; temp = L^{-1} K
  let temp-mat solve-lower-left lower-chol reduced-k

  ;; A = temp * L^{-T}
  ;; equivalente a: A = transpose( L^{-1} * transpose(temp) )
  let standard-a matrix-transpose (solve-lower-left lower-chol (matrix-transpose temp-mat))

  report standard-a
end


; ----------------------------------------------------------
; UTILIDADES PARA JACOBI
; ----------------------------------------------------------

;; Extrae la diagonal principal de una matriz.
to-report matrix-diagonal [mat]
  let result []
  let i 0

  while [i < length mat] [
    set result lput (item i (item i mat)) result
    set i i + 1
  ]

  report result
end


;; Busca la posicion y el valor maximo fuera de la diagonal
;; de una matriz simetrica.
to-report max-offdiag-position [mat]
  let n length mat
  let best-row 0
  let best-col 1
  let best-value 0

  let row-index 0
  while [row-index < n] [
    let col-index (row-index + 1)
    while [col-index < n] [
      let candidate abs (item col-index (item row-index mat))
      if candidate > best-value [
        set best-value candidate
        set best-row row-index
        set best-col col-index
      ]
      set col-index col-index + 1
    ]
    set row-index row-index + 1
  ]

  report (list best-row best-col best-value)
end

;; Calcula autovalores aproximados mediante el metodo de Jacobi.
to-report jacobi-eigenvalues [input-matrix tolerance max-rotations]
  let mat input-matrix
  let n length mat
  let sweep 0

  while [sweep < max-rotations] [
    let pivot-info max-offdiag-position mat
    let p item 0 pivot-info
    let q item 1 pivot-info
    let off-value item 2 pivot-info

    if off-value < tolerance [
      set sweep max-rotations
    ]

    if off-value >= tolerance [
      let app item p (item p mat)
      let aqq item q (item q mat)
      let apq item q (item p mat)

      let tau ((aqq - app) / (2 * apq))
      let t 0

      ifelse tau >= 0
      [ set t (1 / (tau + sqrt (1 + tau * tau))) ]
      [ set t (-1 / ((- tau) + sqrt (1 + tau * tau))) ]

      let c (1 / sqrt (1 + t * t))
      let s (t * c)

      ;; actualizar filas/columnas p y q
      let r 0
      while [r < n] [
        if (r != p) and (r != q) [
          let arp item p (item r mat)
          let arq item q (item r mat)

          let new-arp (c * arp - s * arq)
          let new-arq (s * arp + c * arq)

          set mat matrix-set mat r p new-arp
          set mat matrix-set mat p r new-arp

          set mat matrix-set mat r q new-arq
          set mat matrix-set mat q r new-arq
        ]
        set r r + 1
      ]

      let new-app (c * c * app - 2 * s * c * apq + s * s * aqq)
      let new-aqq (s * s * app + 2 * s * c * apq + c * c * aqq)

      set mat matrix-set mat p p new-app
      set mat matrix-set mat q q new-aqq
      set mat matrix-set mat p q 0
      set mat matrix-set mat q p 0
    ]

    set sweep sweep + 1
  ]

  report matrix-diagonal mat
end



;; Calcula las dos primeras frecuencias naturales del domo
;; usando un numero dado de iteraciones de Jacobi.
to-report first-two-natural-frequencies-with-rotations [design jacobi-rotations]
  let global-k assemble-global-stiffness design
  let global-m assemble-global-mass design

  let reduced-k submatrix-by-indices global-k free-dofs
  let reduced-m submatrix-by-indices global-m free-dofs

  let standard-a generalized-to-standard-matrix-full reduced-k reduced-m

  if standard-a = nobody [
    report (list 0 0)
  ]

  let eigvals jacobi-eigenvalues standard-a 1.0e-10 jacobi-rotations
  let positive-eigvals sort (filter [lam -> lam > 1.0e-10] eigvals)

  if length positive-eigvals < 2 [
    report (list 0 0)
  ]

  let lambda-1 item 0 positive-eigvals
  let lambda-2 item 1 positive-eigvals

  let frequency-1 (sqrt lambda-1 / (2 * pi))
  let frequency-2 (sqrt lambda-2 / (2 * pi))

  report (list frequency-1 frequency-2)
end


;; Calcula el peso real total del domo a partir de las 7 areas del diseño.
to-report compute-real-weight [design]
  let member-areas expand-design-to-members design
  let total-weight 0
  let elem-index 0

  while [elem-index < length member-areas] [
    let area-value item elem-index member-areas
    let member-length item elem-index member-lengths

    set total-weight total-weight + (effective-density * area-value * member-length)
    set elem-index elem-index + 1
  ]

  report total-weight
end


; ----------------------------------------------------------
; REPORTERS
; ----------------------------------------------------------


;; Devuelve el mejor diseño global en formato texto
;; para mostrarlo en un monitor de la interfaz.
to-report g-best-vars-text
  if (not is-list? g-best-vars) or empty? g-best-vars [
    report "Sin inicializar"
  ]

  report (word
    "A1=" precision (item 0 g-best-vars) 4 "\n"
    "A2=" precision (item 1 g-best-vars) 4 "\n"
    "A3=" precision (item 2 g-best-vars) 4 "\n"
    "A4=" precision (item 3 g-best-vars) 4 "\n"
    "A5=" precision (item 4 g-best-vars) 4 "\n"
    "A6=" precision (item 5 g-best-vars) 4 "\n"
    "A7=" precision (item 6 g-best-vars) 4
  )
end


;; Devuelve el valor del mejor fitness global
;; en formato reducido para la interfaz.
to-report g-best-val-text
  report precision g-best-val 6
end



;; Actualiza las metricas cacheadas de la interfaz:
;; peso, frecuencias, violacion, factibilidad y margenes.
;; Se usa para evitar recalcular el FEM continuamente en monitores.
to update-ui-metrics
  if (not is-list? g-best-vars) or empty? g-best-vars [
    set ui-best-weight 0
    set ui-best-f1 0
    set ui-best-f2 0
    set ui-best-violation 0
    set ui-best-feasible "NO"
    set ui-best-margin-f1 0
    set ui-best-margin-f2 0
    stop
  ]

  let freqs first-two-natural-frequencies-accurate g-best-vars
  let f1 item 0 freqs
  let f2 item 1 freqs

  let viol 0
  if f1 < min-frequency-1 [
    set viol viol + ((min-frequency-1 - f1) / min-frequency-1)
  ]
  if f2 < min-frequency-2 [
    set viol viol + ((min-frequency-2 - f2) / min-frequency-2)
  ]

  set ui-best-weight compute-real-weight g-best-vars
  set ui-best-f1 f1
  set ui-best-f2 f2
  set ui-best-violation viol
  set ui-best-margin-f1 (f1 - min-frequency-1)
  set ui-best-margin-f2 (f2 - min-frequency-2)

  ifelse viol = 0
  [ set ui-best-feasible "SI" ]
  [ set ui-best-feasible "NO" ]
end


; ==========================================================
; NUCLEO CSA 
; Implementa las tres etapas consecutivas del algoritmo:
; (1) búsqueda/percepción, (2) rotación de ojos, (3) lengua.
; ==========================================================


;; Devuelve el parámetro μ(t) del paper.
;; μ controla el equilibrio exploración/explotación y decrece con las iteraciones.
to-report mu-paper [iter-num max-iter]
  let ratio (iter-num / max-iter)
  report (csa-gamma * exp ( - ((csa-alpha * ratio) ^ csa-beta) ))
end

;; Devuelve ω(t), el factor de inercia usado en la fase de lengua.
to-report omega-paper [iter-num max-iter]
  report (1 - (iter-num / max-iter))
end

;; Devuelve la aceleracion usada en la fase de lengua.
;; Se limita para evitar divisiones por cero o valores demasiado pequeños.
to-report accel-paper [iter-num]
  let a (2590 * (1 - (1 / (iter-num + 1))))
  if a < 1 [
    set a 1
  ]
  report a
end



;; Implementa la fase de busqueda/percepcion del CSA.
;; Combina una rama guiada por p-best y g-best con una rama
;; de exploracion aleatoria proporcional al rango de busqueda.
to-report csa-search-step [x pbest gbest iter-num max-iter]
  ;; Blindajes contra listas vacías o mal formadas
  if not valid-design-list? x [
    report random-design
  ]

  if not valid-design-list? pbest [
    set pbest copy-design x
  ]

  if not valid-design-list? gbest [
    set gbest copy-design pbest
  ]

  if (not is-list? lower-bounds) or (length lower-bounds != number-of-groups) [
    report copy-design x
  ]

  if (not is-list? upper-bounds) or (length upper-bounds != number-of-groups) [
    report copy-design x
  ]

  let mu mu-paper iter-num max-iter
  let result []
  let j 0

  while [j < length x] [
    let xj item j x
    let pj item j pbest
    let gj item j gbest
    let lj item j lower-bounds
    let uj item j upper-bounds

    let r1 random-float 1.0
    let r2 random-float 1.0
    let r3 random-float 1.0
    let ri random-float 1.0

    let sign-dir 1
    if (random-float 1.0) < 0.5 [ set sign-dir -1 ]

    let new-xj xj

    ifelse (ri >= csa-Pp)
    [
      ;; Eq. (3), primer estado
      set new-xj (xj + (csa-p1 * (pj - gj) * r2) + (csa-p2 * (gj - xj) * r1))
    ]
    [
      ;; Eq. (3), segundo estado
      set new-xj (xj + mu * (uj - lj) * r3 * sign-dir)
    ]

    ;; Limitar al dominio
    if new-xj < lj [ set new-xj lj ]
    if new-xj > uj [ set new-xj uj ]

    set result lput new-xj result
    set j j + 1
  ]

  report result
end



;; Implementa una aproximacion practica de la rotacion ocular:
;; rota el desplazamiento del camaleon en un plano aleatorio de dos dimensiones.
to-report csa-eye-rotation-step [x-old x-search]
  let d length x-old
  if d < 2 [ report x-search ]

  ;; elegir dos dimensiones distintas
  let i random d
  let j random d
  while [j = i] [
    set j random d
  ]

  ;; ángulo theta = r * sgn(rand-0.5) * 180 grados
  let r random-float 1.0
  let sign-dir 1
  if (random-float 1.0) < 0.5 [ set sign-dir -1 ]
  let theta (r * sign-dir * 180)

  ;; vector centrado respecto a la posición actual
  let yc vec-sub x-search x-old

  let yi item i yc
  let yj item j yc

  ;; rotación plana
  let new-yi ((yi * cos theta) - (yj * sin theta))
  let new-yj ((yi * sin theta) + (yj * cos theta))

  let yc-rot replace-item i yc new-yi
  set yc-rot replace-item j yc-rot new-yj

  let rotated vec-add x-old yc-rot

  report vec-clip rotated lower-bounds upper-bounds
end



;; Implementa la fase de lengua del CSA:
;; actualiza velocidad y posicion segun el esquema cinemático del algoritmo.
to-report csa-tongue-step [x-current pbest gbest old-vel iter-num max-iter]
  let omega omega-paper iter-num max-iter
  let a accel-paper iter-num

  let new-pos []
  let new-vel []

  let j 0
  while [j < length x-current] [
    let xj item j x-current
    let pj item j pbest
    let gj item j gbest
    let v-old item j old-vel

    let r1 random-float 1.0
    let r2 random-float 1.0

    ;; Eq. (18)
    let v-new ((omega * v-old) +
               (csa-c1 * (gj - xj) * r1) +
               (csa-c2 * (pj - xj) * r2))

    ;; Eq. (20)
    let x-new (xj + (((v-new * v-new) - (v-old * v-old)) / (2 * a)))

    let lj item j lower-bounds
    let uj item j upper-bounds

    if x-new < lj [ set x-new lj ]
    if x-new > uj [ set x-new uj ]

    set new-pos lput x-new new-pos
    set new-vel lput v-new new-vel

    set j j + 1
  ]

  report (list new-pos new-vel)
end



;; Aplica aceptacion greedy:
;; un candidato solo se adopta si mejora el fitness actual.
;; Usa evaluacion rapida como filtro y precisa para confirmacion.
to csa-greedy-move [candidate-vars candidate-fast-val candidate-vel]
  let candidate-weight compute-real-weight candidate-vars

  ;; si la actual ya es factible y el candidato pesa igual o más, no merece validar
  if (abs (current-val - current-weight) < 1.0e-9) and (candidate-weight >= current-weight) [
    stop
  ]

  ;; si la evaluación rápida no parece mejorar, no validamos preciso
  if candidate-fast-val < current-val [
    let candidate-accurate-val evaluate-design-120-accurate candidate-vars

    if candidate-accurate-val < current-val [
      set vars candidate-vars
      set current-val candidate-accurate-val
      set current-weight candidate-weight
      set vel candidate-vel
    ]
  ]
end


to-report valid-design-list? [x]
  if not is-list? x [ report false ]
  if length x != number-of-groups [ report false ]
  report true
end




;; Iteracion principal del CSA:
;; actualiza mejores, aplica las tres fases del algoritmo
;; y refresca interfaz y graficos periodicamente.
to go

  if not model-ready? [
    user-message "Primero debes ejecutar setup."
    stop
  ]

  if ticks >= max-iterations [ stop ]

  ;; red de seguridad: asegurar g-best válido al inicio
  update-personal-global-best

  let iter-num (ticks + 1)
  let max-iter max-iterations

  ask particles [
    ;; si por algún motivo p-best no está bien, lo resembramos
    if not valid-design-list? p-best-vars [
      set p-best-vars copy-design vars
      set p-best-val current-val
    ]

    let x0 copy-design vars
    let old-vel vel

    ;; Paso 1: búsqueda / percepción
    let x1 csa-search-step x0 p-best-vars g-best-vars iter-num max-iter
    let f1 evaluate-design x1
    csa-greedy-move x1 f1 old-vel

    let x-after-search vars

    ;; Paso 2: rotación de ojos
    let x2 csa-eye-rotation-step x0 x-after-search
    let f2 evaluate-design x2
    csa-greedy-move x2 f2 old-vel

    let x-after-eye vars

    ;; Paso 3: ataque con la lengua
    let tongue-output csa-tongue-step x-after-eye p-best-vars g-best-vars old-vel iter-num max-iter
    let x3 item 0 tongue-output
    let v3 item 1 tongue-output
    let f3 evaluate-design x3
    csa-greedy-move x3 f3 v3
  ]

  update-personal-global-best


  if ticks mod 20 = 0 [
    update-ui-metrics
    update-plots
  ]
  if ticks = (max-iterations - 1) [
      update-ui-metrics
    update-plots
  ]

  tick
end






; ==========================================================
; DEBUG Y VALIDACION
; Funciones auxiliares para depuracion y analisis manual.
; No forman parte del uso normal desde la interfaz.
; ==========================================================


;; Ejecuta n iteraciones y muestra por consola
;; el mejor fitness y el mejor diseño en cada paso.
to trace-csa [n]
  let k 0
  while [k < n] [
    go
    show (word "tick = " ticks)
    show (word "g-best-val = " precision g-best-val 6)
    show (word "g-best-vars = " g-best-vars)
    set k k + 1
  ]
end

;; Imprime un resumen del modelo estructural del domo.
to print-120bar-model-summary
  show "=============================================="
  show "RESUMEN MODELO DOMO 120 BARRAS"
  show "=============================================="

  show (word "NODOS = " length node-coords)
  show (word "BARRAS = " length member-connectivity)
  show (word "GRUPOS (conteo) = " member-group-counts)
  show (word "NODOS APOYADOS = " length support-node-ids)
  show (word "DOFS TOTALES = " total-dofs)
  show (word "DOFS LIBRES = " length free-dofs)

  show "=============================================="
end

;; Comprueba si el modelo generado coincide con los datos esperados del benchmark.
to check-120bar-benchmark-consistency
  show "=============================================="
  show "CHECK CONSISTENCIA BENCHMARK 120-BAR"
  show "=============================================="

  ifelse (length node-coords = 49)
    [ show "OK: numero de nodos = 49" ]
    [ show (word "ERROR: nodos = " length node-coords " (esperado 49)") ]

  ifelse (length member-connectivity = 120)
    [ show "OK: numero de barras = 120" ]
    [ show (word "ERROR: barras = " length member-connectivity " (esperado 120)") ]

  ifelse (member-group-counts = [12 12 12 24 24 12 24])
    [ show "OK: grupos = [12 12 12 24 24 12 24]" ]
    [ show (word "ERROR: grupos = " member-group-counts) ]

  ifelse (length support-node-ids = 12)
    [ show "OK: nodos apoyados = 12" ]
    [ show (word "ERROR: apoyos = " length support-node-ids " (esperado 12)") ]

  ifelse (total-dofs = 147)
    [ show "OK: dofs totales = 147" ]
    [ show (word "ERROR: dofs totales = " total-dofs " (esperado 147)") ]

  ifelse (length free-dofs = 111)
    [ show "OK: dofs libres = 111" ]
    [ show (word "ERROR: dofs libres = " length free-dofs " (esperado 111)") ]

  show "=============================================="
end


;; Imprime por consola el mejor diseño actual y su peso real.
to print-current-best-design
  show "=============================================="
  show "MEJOR DISENO ACTUAL"
  show "=============================================="

  if (not is-list? g-best-vars) or empty? g-best-vars [
    show "No hay mejor diseño disponible"
    stop
  ]

  show (word
    "A1=" precision (item 0 g-best-vars) 4
    "  A2=" precision (item 1 g-best-vars) 4
    "  A3=" precision (item 2 g-best-vars) 4
    "  A4=" precision (item 3 g-best-vars) 4
    "  A5=" precision (item 4 g-best-vars) 4
    "  A6=" precision (item 5 g-best-vars) 4
    "  A7=" precision (item 6 g-best-vars) 4
  )

  show (word "fitness actual = " precision g-best-val 6)
  show (word "peso real = " precision (compute-real-weight g-best-vars) 6 " kg")

  show "=============================================="
end


;; Imprime por consola el estado dinamico del mejor diseño actual:
;; frecuencias, violacion, peso y fitness.
to print-current-best-dynamic-status
  let best-design g-best-vars

  if (not is-list? best-design) or empty? best-design [
    show "No hay mejor diseño disponible"
    stop
  ]

  let freqs first-two-natural-frequencies-accurate best-design
  let frequency-1 item 0 freqs
  let frequency-2 item 1 freqs

  let violation 0
  if frequency-1 < min-frequency-1 [
    set violation violation + ((min-frequency-1 - frequency-1) / min-frequency-1)
  ]
  if frequency-2 < min-frequency-2 [
    set violation violation + ((min-frequency-2 - frequency-2) / min-frequency-2)
  ]

  show "=============================================="
  show "ESTADO DINAMICO DEL MEJOR DISENO ACTUAL"
  show "=============================================="
  show (word "f1 = " precision frequency-1 6 " Hz")
  show (word "f2 = " precision frequency-2 6 " Hz")
  show (word "f1 minima = " precision min-frequency-1 6 " Hz")
  show (word "f2 minima = " precision min-frequency-2 6 " Hz")
  show (word "violacion total = " precision violation 6)
  show (word "peso real = " precision (compute-real-weight best-design) 6 " kg")
  show (word "fitness penalizado = " precision (evaluate-design-120-accurate best-design) 6)
  show "=============================================="
end


;; Imprime el peso aportado por cada grupo de barras de un diseño dado.
to print-weight-breakdown-for-design [design]
  let expected-counts member-group-counts
  let start-index 0
  let group-index 0
  let total-weight 0

  show "=============================================="
  show "DESGLOSE DE PESO POR GRUPO"
  show "=============================================="

  while [group-index < length design] [
    let area-cm2 item group-index design
    let area-m2 (area-cm2 * 1.0e-4)
    let group-size item group-index expected-counts

    let group-weight 0
    let local-index 0

    while [local-index < group-size] [
      let elem-index (start-index + local-index)
      let member-length item elem-index member-lengths
      set group-weight group-weight + (effective-density * area-m2 * member-length)
      set local-index local-index + 1
    ]

    set total-weight total-weight + group-weight

    show (word
      "Grupo " (group-index + 1)
      " | area = " precision area-cm2 6 " cm^2"
      " | barras = " group-size
      " | peso grupo = " precision group-weight 6 " kg"
    )

    set start-index (start-index + group-size)
    set group-index (group-index + 1)
  ]

  show "----------------------------------------------"
  show (word "PESO TOTAL = " precision total-weight 6 " kg")
  show "=============================================="
end

;; Imprime la longitud total asociada a cada grupo de barras.
to print-group-length-breakdown
  let start-index 0
  let group-index 0

  show "=============================================="
  show "LONGITUD TOTAL POR GRUPO"
  show "=============================================="

  while [group-index < length member-group-counts] [
    let group-size item group-index member-group-counts
    let group-length-total 0
    let local-index 0

    while [local-index < group-size] [
      let elem-index (start-index + local-index)
      set group-length-total group-length-total + (item elem-index member-lengths)
      set local-index local-index + 1
    ]

    show (word
      "Grupo " (group-index + 1)
      " | barras = " group-size
      " | longitud total = " precision group-length-total 6 " m"
    )

    set start-index (start-index + group-size)
    set group-index (group-index + 1)
  ]

  show "=============================================="
end


;; Estudia la convergencia del calculo modal
;; al variar el numero de iteraciones de Jacobi.
to print-jacobi-rotation-study [design]
  let rotation-list [2000 5000 12000 20000 40000]

  show "=============================================="
  show "ESTUDIO DE CONVERGENCIA DE JACOBI"
  show "=============================================="

  foreach rotation-list [nrot ->
    let freqs first-two-natural-frequencies-with-rotations design nrot
    show (word
      "rotaciones = " nrot
      " | f1 = " precision (item 0 freqs) 6 " Hz"
      " | f2 = " precision (item 1 freqs) 6 " Hz"
    )
  ]

  show "=============================================="
end











