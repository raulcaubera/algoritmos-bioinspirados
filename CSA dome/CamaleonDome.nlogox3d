  show (word "BARRAS = " length member-connectivity)
  show (word "GRUPOS (conteo) = " member-group-counts)
  show (word "NODOS APOYADOS = " length support-node-ids)
  show (word "DOFS TOTALES = " total-dofs)
  show (word "DOFS RESTRINGIDOS = " length restrained-dofs)
  show (word "DOFS LIBRES = " length free-dofs)

  show (word "ANILLO EXTERIOR = " outer-ring-node-ids)
  show (word "ANILLO INTERMEDIO = " mid-ring-node-ids)
  show (word "ANILLO SUPERIOR = " upper-ring-node-ids)
  show (word "APICE = " apex-node-id)

  show (word "LONGITUD MIN = " precision (min member-lengths) 6 " m")
  show (word "LONGITUD MAX = " precision (max member-lengths) 6 " m")

