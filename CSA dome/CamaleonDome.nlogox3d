  show (word "BARRAS = " length member-connectivity)
  show (word "GRUPOS (conteo) = " member-group-counts)
  show (word "NODOS APOYADOS = " length support-node-ids)
  show (word "DOFS TOTALES = " total-dofs)
  show (word "DOFS LIBRES = " length free-dofs)

  show "=============================================="
end

