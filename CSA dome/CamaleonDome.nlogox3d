<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 3D 7.0.3" snapToGrid="false">
  <code><![CDATA[; ==========================================================
;  CSA — Algoritmo de Enjambre de Camaleones
;  Versión refactorizada para diseño estructural vectorial
;  (preparada para el domo de 120 barras, 7 variables)
; ==========================================================

breed [ particles particle ]

globals [
  g-best-vars         ;; mejor solución global (lista)
  g-best-val          ;; mejor fitness global

  number-of-groups    ;; número de variables de diseño
  lower-bounds        ;; lista de límites inferiores
  upper-bounds        ;; lista de límites superiores
  
  ;; parámetros base del benchmark
  base-young-modulus
  base-density
  base-frequency-1
  base-frequency-2

  ;; parámetros efectivos (modificados por sliders)
  effective-young-modulus
  effective-density
  min-frequency-1
  min-frequency-2

  ;; masas nodales no estructurales efectivas
  apex-extra-mass
  upper-ring-extra-mass
  mid-ring-extra-mass
  
  
  ;; --- modelo del domo de 120 barras ---
  node-coords
  member-connectivity
  member-lengths

  support-node-ids
  total-dofs
  restrained-dofs
  free-dofs

  member-group-counts

  apex-node-id
  upper-ring-node-ids
  mid-ring-node-ids
  outer-ring-node-ids

]

particles-own [
  vars                ;; solución actual de la partícula: lista de variables
  vel                 ;; velocidad vectorial
  p-best-vars         ;; mejor solución personal
  p-best-val          ;; mejor fitness personal
  current-val         ;; fitness actual
]


; ----------------------------------------------------------
; REPORTERS
; ----------------------------------------------------------
to-report g-best-vars-text
  let best-design best-design-now

  if (not is-list? best-design) or empty? best-design [
    report "Sin inicializar"
  ]

  report (word
    "A1=" precision (item 0 best-design) 4 "\n"
    "A2=" precision (item 1 best-design) 4 "\n"
    "A3=" precision (item 2 best-design) 4 "\n"
    "A4=" precision (item 3 best-design) 4 "\n"
    "A5=" precision (item 4 best-design) 4 "\n"
    "A6=" precision (item 5 best-design) 4 "\n"
    "A7=" precision (item 6 best-design) 4
  )
end




to-report g-best-val-text
  report precision best-val-now 6
end

to-report model-node-count
  report length node-coords
end

to-report model-member-count
  report length member-connectivity
end

to-report model-group-counts
  report member-group-counts
end

to-report model-support-count
  report length support-node-ids
end

to-report model-total-dofs
  report total-dofs
end

to-report model-free-dofs-count
  report length free-dofs
end

to-report unique-member-lengths
  let rounded []
  let i 0

  while [i < length member-lengths] [
    set rounded lput (precision (item i member-lengths) 4) rounded
    set i i + 1
  ]

  report remove-duplicates sort rounded
end


to-report element-consistent-mass-3d [area node-i node-j]
  let elem-length distance-between-nodes node-i node-j
  let coeff (effective-density * area * elem-length / 6)

  report (list
    (list (2 * coeff) 0 0 coeff 0 0)
    (list 0 (2 * coeff) 0 0 coeff 0)
    (list 0 0 (2 * coeff) 0 0 coeff)

    (list coeff 0 0 (2 * coeff) 0 0)
    (list 0 coeff 0 0 (2 * coeff) 0)
    (list 0 0 coeff 0 0 (2 * coeff))
  )
end

to-report copy-design [design]
  if (not is-list? design) or (length design != 7) [
    report []
  ]

  report (list
    (item 0 design)
    (item 1 design)
    (item 2 design)
    (item 3 design)
    (item 4 design)
    (item 5 design)
    (item 6 design)
  )
end

to-report live-best-vars
  if not any? particles [
    report []
  ]

  let best-particle min-one-of particles [p-best-val]
  let best-design [p-best-vars] of best-particle

  if (not is-list? best-design) or (length best-design != 7) [
    report []
  ]

  report (list
    (item 0 best-design)
    (item 1 best-design)
    (item 2 best-design)
    (item 3 best-design)
    (item 4 best-design)
    (item 5 best-design)
    (item 6 best-design)
  )
end

to-report live-best-val
  if not any? particles [
    report 1.0E+20
  ]

  let best-particle min-one-of particles [p-best-val]
  report [p-best-val] of best-particle
end


to sync-global-best
  set g-best-vars live-best-vars
  set g-best-val live-best-val
end


to-report best-design-now
  report live-best-vars
end

to-report best-val-now
  report live-best-val
end



; ----------------------------------------------------------
; SETUP
; ----------------------------------------------------------
to setup
  clear-all
  reset-ticks

  set g-best-vars []
  set g-best-val 1.0E+20

  setup-design-space
  build-120bar-model

  initialize-particles
  sync-global-best
end



; ----------------------------------------------------------
; ESPACIO DE DISEÑO DEL PROBLEMA
; ----------------------------------------------------------
to setup-design-space
  ;; 7 grupos del domo de 120 barras
  set number-of-groups 7

  ;; áreas continuas entre 1 y 129.3 cm^2
  set lower-bounds n-values number-of-groups [ -> 1.0 ]
  set upper-bounds n-values number-of-groups [ -> 129.3 ]

  ;; datos base del benchmark
  set base-young-modulus 210e9
  set base-density 7971.810
  set base-frequency-1 9
  set base-frequency-2 11

  ;; aplicar sliders de sensibilidad
  set effective-young-modulus (base-young-modulus * young-modulus-factor)
  set effective-density (base-density * density-factor)

  set min-frequency-1 (base-frequency-1 * frequency-target-factor)
  set min-frequency-2 (base-frequency-2 * frequency-target-factor)

  ;; masas no estructurales efectivas
  ;; benchmark base: 3000 kg, 500 kg, 100 kg
  set apex-extra-mass       (3000 * nonstructural-mass-factor)
  set upper-ring-extra-mass (500  * nonstructural-mass-factor)
  set mid-ring-extra-mass   (100  * nonstructural-mass-factor)
end


; ----------------------------------------------------------
; INICIALIZACIÓN DE PARTÍCULAS
; ----------------------------------------------------------

to initialize-particles
  create-particles population-size [
    set vars random-design
    set vel random-normal-vector number-of-groups 0.5

    set current-val evaluate-design vars
    set p-best-vars copy-design vars
    set p-best-val current-val
    
    ;; visualmente ya no importa el espacio 2D real
    ;; las tortugas solo actúan como contenedores/agentes
    hide-turtle
  ]
end





; ==========================================================
; MODELO DEL DOMO DE 120 BARRAS
; Basado en el benchmark de 49 nodos / 120 barras / 7 grupos
; ==========================================================

to build-120bar-model
  ;; 49 nodos espaciales, 3 DOFs por nodo
  set total-dofs (49 * 3)

  ;; grupos del benchmark: 12, 12, 12, 24, 24, 12, 24 = 120
  set member-group-counts [12 12 12 24 24 12 24]

  ;; apoyos: anillo exterior
  set outer-ring-node-ids n-values 12 [i -> i + 1]
  set support-node-ids outer-ring-node-ids

  ;; nodos útiles para masas nodales posteriores
  set mid-ring-node-ids   n-values 24 [i -> i + 13]   ;; 13..36
  set upper-ring-node-ids n-values 12 [i -> i + 37]   ;; 37..48
  set apex-node-id 49

  build-120bar-node-coords
  build-120bar-connectivity
  build-120bar-member-lengths

  set restrained-dofs build-restrained-dofs
  set free-dofs build-free-dofs
end

;; coordenadas nodales
to build-120bar-node-coords
  set node-coords []

  ;; ----------------------------------------
  ;; Nodos 1..12  : anillo exterior
  ;; radio = 15.89 m, z = 0 m
  ;; 12 nodos -> incremento angular de 30 grados
  ;; ----------------------------------------
  let i 0
  while [i < 12] [
    let theta-deg (i * 30)
    let x (15.89 * cos theta-deg)
    let y (15.89 * sin theta-deg)
    let z 0
    set node-coords lput (list x y z) node-coords
    set i i + 1
  ]

  ;; ----------------------------------------
  ;; Nodos 13..36 : anillo intermedio
  ;; radio = 12.04 m, z = 3 m
  ;; 24 nodos -> incremento angular de 15 grados
  ;; ----------------------------------------
  set i 0
  while [i < 24] [
    let theta-deg (i * 15)
    let x (12.04 * cos theta-deg)
    let y (12.04 * sin theta-deg)
    let z 3
    set node-coords lput (list x y z) node-coords
    set i i + 1
  ]

  ;; ----------------------------------------
  ;; Nodos 37..48 : anillo superior
  ;; radio = 6.94 m, z = 5.85 m
  ;; 12 nodos -> incremento angular de 30 grados
  ;; ----------------------------------------
  set i 0
  while [i < 12] [
    let theta-deg (i * 30)
    let x (6.94 * cos theta-deg)
    let y (6.94 * sin theta-deg)
    let z 5.85
    set node-coords lput (list x y z) node-coords
    set i i + 1
  ]

  ;; ----------------------------------------
  ;; Nodo 49 : ápice
  ;; ----------------------------------------
  set node-coords lput (list 0 0 7.0) node-coords
end



;;Conectividad de las 120 barras
to build-120bar-connectivity
  set member-connectivity []

  ;; ======================================================
  ;; GRUPO 1 (12 barras)
  ;; Ápice (49) conectado al anillo superior (37..48)
  ;; ======================================================
  let i 1
  while [i <= 12] [
    set member-connectivity lput (list 49 (49 - i)) member-connectivity
    set i i + 1
  ]

  ;; ======================================================
  ;; GRUPO 2 (12 barras)
  ;; Anillo superior circunferencial: 37-38-...-48-37
  ;; ======================================================
  set i 1
  while [i <= 11] [
    set member-connectivity lput (list (36 + i) (36 + i + 1)) member-connectivity
    set i i + 1
  ]
  set member-connectivity lput (list 48 37) member-connectivity

  ;; ======================================================
  ;; GRUPO 3 (12 barras)
  ;; Conexión anillo superior → anillo intermedio
  ;; patrón radial
  ;; ======================================================
  set i 1
  while [i <= 12] [
    set member-connectivity lput (list (36 + i) (2 * i + 11)) member-connectivity
    set i i + 1
  ]

  ;; ======================================================
  ;; GRUPO 4 (24 barras)
  ;; Diagonales entre anillo superior e intermedio
  ;; ======================================================
  set i 1
  while [i <= 11] [
    set member-connectivity lput (list (37 + i) (2 * i + 12)) member-connectivity
    set member-connectivity lput (list (37 + i) (2 * i + 14)) member-connectivity
    set i i + 1
  ]
  set member-connectivity lput (list 37 36) member-connectivity
  set member-connectivity lput (list 37 14) member-connectivity

  ;; ======================================================
  ;; GRUPO 5 (24 barras)
  ;; Anillo intermedio circunferencial: 13-14-...-36-13
  ;; ======================================================
  set i 1
  while [i <= 23] [
    set member-connectivity lput (list (12 + i) (12 + i + 1)) member-connectivity
    set i i + 1
  ]
  set member-connectivity lput (list 36 13) member-connectivity

  ;; ======================================================
  ;; GRUPO 6 (12 barras)
  ;; Conexión anillo intermedio → anillo exterior
  ;; patrón radial
  ;; ======================================================
  set i 1
  while [i <= 12] [
    set member-connectivity lput (list (11 + 2 * i) i) member-connectivity
    set i i + 1
  ]

  ;; ======================================================
  ;; GRUPO 7 (24 barras)
  ;; Diagonales entre anillo exterior e intermedio
  ;; ======================================================
  set i 2
  while [i <= 12] [
    set member-connectivity lput (list i (2 * i + 10)) member-connectivity
    set member-connectivity lput (list i (2 * i + 12)) member-connectivity
    set i i + 1
  ]
  set member-connectivity lput (list 1 14) member-connectivity
  set member-connectivity lput (list 1 36) member-connectivity
end

;;Longitudes de las barras
to build-120bar-member-lengths
  set member-lengths []

  let i 0
  while [i < length member-connectivity] [
    let conn item i member-connectivity
    let ni first conn
    let nj last conn

    set member-lengths lput (distance-between-nodes ni nj) member-lengths
    set i i + 1
  ]
end





to-report node-xyz [node-id]
  report item (node-id - 1) node-coords
end


to-report distance-between-nodes [ni nj]
  let p node-xyz ni
  let q node-xyz nj

  let delta-x ((item 0 q) - (item 0 p))
  let delta-y ((item 1 q) - (item 1 p))
  let delta-z ((item 2 q) - (item 2 p))

  report sqrt (delta-x * delta-x + delta-y * delta-y + delta-z * delta-z)
end


to-report node-dof-indices [node-id]
  let base (3 * (node-id - 1))
  report (list base (base + 1) (base + 2))
end

to-report build-restrained-dofs
  let result []
  let i 0

  while [i < length support-node-ids] [
    let node-id item i support-node-ids
    let dofs node-dof-indices node-id
    set result sentence result dofs
    set i i + 1
  ]

  report result
end


to-report build-free-dofs
  let result []
  let d 0

  while [d < total-dofs] [
    if not member? d restrained-dofs [
      set result lput d result
    ]
    set d d + 1
  ]

  report result
end

to-report element-dof-indices [node-i node-j]
  report sentence (node-dof-indices node-i) (node-dof-indices node-j)
end



;;Expansión del diseño de 7 variables a 120 barras reales
to-report expand-design-to-members [design]
  ;; design = [A1 ... A7] en cm^2
  ;; salida = lista de 120 áreas en m^2

  let member-areas []
  let group-index 0

  while [group-index < length design] [
    let area-cm2 item group-index design
    let area-m2 (area-cm2 * 1.0e-4)

    let group-size item group-index member-group-counts
    let local-index 0

    while [local-index < group-size] [
      set member-areas lput area-m2 member-areas
      set local-index local-index + 1
    ]

    set group-index group-index + 1
  ]

  report member-areas
end









  
;;Ceros: vector y matriz
to-report zero-vector [n]
  report n-values n [ i -> 0 ]
end

to-report zero-matrix [rows cols]
  report n-values rows [ r -> n-values cols [ c -> 0 ] ]
end

;;Reemplazar un valor en una matriz
to-report matrix-set [mat row-index col-index new-value]
  let selected-row item row-index mat
  let updated-row replace-item col-index selected-row new-value
  report replace-item row-index mat updated-row
end


;;Sumar a una posición concreta de la matriz
to-report matrix-add [mat row-index col-index increment]
  let current-value item col-index (item row-index mat)
  report matrix-set mat row-index col-index (current-value + increment)
end


;;Extraer un subvector por índices
to-report subvector-by-indices [full-vector index-list]
  let result []
  let idx-pos 0

  while [idx-pos < length index-list] [
    let dof-index item idx-pos index-list
    set result lput (item dof-index full-vector) result
    set idx-pos idx-pos + 1
  ]

  report result
end

;;Extraer una submatriz por índices
to-report submatrix-by-indices [full-matrix index-list]
  let result []
  let row-pos 0

  while [row-pos < length index-list] [
    let row-index item row-pos index-list
    let full-row item row-index full-matrix

    let reduced-row []
    let col-pos 0

    while [col-pos < length index-list] [
      let col-index item col-pos index-list
      set reduced-row lput (item col-index full-row) reduced-row
      set col-pos col-pos + 1
    ]

    set result lput reduced-row result
    set row-pos row-pos + 1
  ]

  report result
end

to-report vector-add-at [vec index increment]
  let current-value item index vec
  report replace-item index vec (current-value + increment)
end

;; rigidez elemental 
to-report element-stiffness-3d [area node-i node-j]
  let coord-i node-xyz node-i
  let coord-j node-xyz node-j

  let x1 item 0 coord-i
  let y1 item 1 coord-i
  let z1 item 2 coord-i

  let x2 item 0 coord-j
  let y2 item 1 coord-j
  let z2 item 2 coord-j

  let delta-x (x2 - x1)
  let delta-y (y2 - y1)
  let delta-z (z2 - z1)

  let elem-length sqrt (delta-x * delta-x + delta-y * delta-y + delta-z * delta-z)

  let dir-cx (delta-x / elem-length)
  let dir-cy (delta-y / elem-length)
  let dir-cz (delta-z / elem-length)

  let coeff (effective-young-modulus * area / elem-length)

  report (list
    (list (coeff * dir-cx * dir-cx) (coeff * dir-cx * dir-cy) (coeff * dir-cx * dir-cz)
          (- coeff * dir-cx * dir-cx) (- coeff * dir-cx * dir-cy) (- coeff * dir-cx * dir-cz))

    (list (coeff * dir-cx * dir-cy) (coeff * dir-cy * dir-cy) (coeff * dir-cy * dir-cz)
          (- coeff * dir-cx * dir-cy) (- coeff * dir-cy * dir-cy) (- coeff * dir-cy * dir-cz))

    (list (coeff * dir-cx * dir-cz) (coeff * dir-cy * dir-cz) (coeff * dir-cz * dir-cz)
          (- coeff * dir-cx * dir-cz) (- coeff * dir-cy * dir-cz) (- coeff * dir-cz * dir-cz))

    (list (- coeff * dir-cx * dir-cx) (- coeff * dir-cx * dir-cy) (- coeff * dir-cx * dir-cz)
          (coeff * dir-cx * dir-cx) (coeff * dir-cx * dir-cy) (coeff * dir-cx * dir-cz))

    (list (- coeff * dir-cx * dir-cy) (- coeff * dir-cy * dir-cy) (- coeff * dir-cy * dir-cz)
          (coeff * dir-cx * dir-cy) (coeff * dir-cy * dir-cy) (coeff * dir-cy * dir-cz))

    (list (- coeff * dir-cx * dir-cz) (- coeff * dir-cy * dir-cz) (- coeff * dir-cz * dir-cz)
          (coeff * dir-cx * dir-cz) (coeff * dir-cy * dir-cz) (coeff * dir-cz * dir-cz))
  )
end


;; ensamblaje de la rigidez
to-report assemble-global-stiffness [design]
  let member-areas expand-design-to-members design
  let global-k zero-matrix total-dofs total-dofs

  let elem-index 0
  while [elem-index < length member-connectivity] [
    let elem-conn item elem-index member-connectivity
    let node-i first elem-conn
    let node-j last elem-conn

    let area item elem-index member-areas
    let elem-k element-stiffness-3d area node-i node-j
    let elem-dofs element-dof-indices node-i node-j

    let local-row 0
    while [local-row < 6] [
      let global-row item local-row elem-dofs

      let local-col 0
      while [local-col < 6] [
        let global-col item local-col elem-dofs
        let k-value item local-col (item local-row elem-k)

        set global-k matrix-add global-k global-row global-col k-value
        set local-col local-col + 1
      ]

      set local-row local-row + 1
    ]

    set elem-index elem-index + 1
  ]

  report global-k
end

;; masa global lummped (matriz diagonal)
to-report assemble-global-mass [design]
  let member-areas expand-design-to-members design
  let global-m zero-matrix total-dofs total-dofs

  ;; ----------------------------------------
  ;; 1) masa estructural consistente de barras
  ;; ----------------------------------------
  let elem-index 0
  while [elem-index < length member-connectivity] [
    let elem-conn item elem-index member-connectivity
    let node-i first elem-conn
    let node-j last elem-conn

    let area-value item elem-index member-areas
    let elem-m element-consistent-mass-3d area-value node-i node-j
    let elem-dofs element-dof-indices node-i node-j

    let local-row 0
    while [local-row < 6] [
      let global-row item local-row elem-dofs

      let local-col 0
      while [local-col < 6] [
        let global-col item local-col elem-dofs
        let m-value item local-col (item local-row elem-m)

        set global-m matrix-add global-m global-row global-col m-value
        set local-col local-col + 1
      ]

      set local-row local-row + 1
    ]

    set elem-index elem-index + 1
  ]

  ;; ----------------------------------------
  ;; 2) masas no estructurales nodales
  ;; (se añaden en la diagonal de los DOFs traslacionales)
  ;; ----------------------------------------

  ;; ápice
  let apex-dofs node-dof-indices apex-node-id
  let ia 0
  while [ia < 3] [
    let dof-index item ia apex-dofs
    set global-m matrix-add global-m dof-index dof-index apex-extra-mass
    set ia ia + 1
  ]

  ;; anillo superior
  let ur-index 0
  while [ur-index < length upper-ring-node-ids] [
    let node-id item ur-index upper-ring-node-ids
    let dofs node-dof-indices node-id

    let k 0
    while [k < 3] [
      let dof-index item k dofs
      set global-m matrix-add global-m dof-index dof-index upper-ring-extra-mass
      set k k + 1
    ]

    set ur-index ur-index + 1
  ]

  ;; anillo intermedio
  let mr-index 0
  while [mr-index < length mid-ring-node-ids] [
    let node-id item mr-index mid-ring-node-ids
    let dofs node-dof-indices node-id

    let k 0
    while [k < 3] [
      let dof-index item k dofs
      set global-m matrix-add global-m dof-index dof-index mid-ring-extra-mass
      set k k + 1
    ]

    set mr-index mr-index + 1
  ]

  report global-m
end


;;.......
to-report matrix-transpose [mat]
  let rows length mat
  let cols length first mat
  let result zero-matrix cols rows

  let row-index 0
  while [row-index < rows] [
    let col-index 0
    while [col-index < cols] [
      let val item col-index (item row-index mat)
      set result matrix-set result col-index row-index val
      set col-index col-index + 1
    ]
    set row-index row-index + 1
  ]

  report result
end

;;...............
to-report cholesky-decomposition [mat]
  let n length mat
  let lower-tri zero-matrix n n

  let row-index 0
  while [row-index < n] [
    let col-index 0
    while [col-index <= row-index] [
      let sum-value 0
      let k 0
      while [k < col-index] [
        set sum-value sum-value +
          ((item k (item row-index lower-tri)) * (item k (item col-index lower-tri)))
        set k k + 1
      ]

      if row-index = col-index [
        let diag-value ((item col-index (item row-index mat)) - sum-value)
        if diag-value <= 0 [
          report nobody
        ]
        set lower-tri matrix-set lower-tri row-index col-index sqrt diag-value
      ]

      if row-index > col-index [
        let lij (((item col-index (item row-index mat)) - sum-value) /
                 (item col-index (item col-index lower-tri)))
        set lower-tri matrix-set lower-tri row-index col-index lij
      ]

      set col-index col-index + 1
    ]
    set row-index row-index + 1
  ]

  report lower-tri
end


;;...............
to-report solve-lower-left [lower-mat rhs-mat]
  let n length lower-mat
  let ncols length first rhs-mat
  let solution-mat zero-matrix n ncols

  let col-index 0
  while [col-index < ncols] [
    let row-index 0
    while [row-index < n] [
      let rhs-value item col-index (item row-index rhs-mat)

      let k 0
      while [k < row-index] [
        set rhs-value rhs-value -
          ((item k (item row-index lower-mat)) * (item col-index (item k solution-mat)))
        set k k + 1
      ]

      let x-value (rhs-value / (item row-index (item row-index lower-mat)))
      set solution-mat matrix-set solution-mat row-index col-index x-value

      set row-index row-index + 1
    ]

    set col-index col-index + 1
  ]

  report solution-mat
end


;; pasar probvlema modal a generalizado estandar
to-report generalized-to-standard-matrix-full [reduced-k reduced-m]
  let lower-chol cholesky-decomposition reduced-m

  if lower-chol = nobody [
    report nobody
  ]

  ;; temp = L^{-1} K
  let temp-mat solve-lower-left lower-chol reduced-k

  ;; A = temp * L^{-T}
  ;; equivalente a: A = transpose( L^{-1} * transpose(temp) )
  let standard-a matrix-transpose (solve-lower-left lower-chol (matrix-transpose temp-mat))

  report standard-a
end





; ----------------------------------------------------------
; UTILIDADES PARA JACOBI
; ----------------------------------------------------------

;;Diagonal de una matriz
to-report matrix-diagonal [mat]
  let result []
  let i 0

  while [i < length mat] [
    set result lput (item i (item i mat)) result
    set i i + 1
  ]

  report result
end

;;Buscar el máximo fuera de diagonal
to-report max-offdiag-position [mat]
  let n length mat
  let best-row 0
  let best-col 1
  let best-value 0

  let row-index 0
  while [row-index < n] [
    let col-index (row-index + 1)
    while [col-index < n] [
      let candidate abs (item col-index (item row-index mat))
      if candidate > best-value [
        set best-value candidate
        set best-row row-index
        set best-col col-index
      ]
      set col-index col-index + 1
    ]
    set row-index row-index + 1
  ]

  report (list best-row best-col best-value)
end


;;Método de Jacobi para autovalores
to-report jacobi-eigenvalues [input-matrix tolerance max-rotations]
  let mat input-matrix
  let n length mat
  let sweep 0

  while [sweep < max-rotations] [
    let pivot-info max-offdiag-position mat
    let p item 0 pivot-info
    let q item 1 pivot-info
    let off-value item 2 pivot-info

    if off-value < tolerance [
      set sweep max-rotations
    ]

    if off-value >= tolerance [
      let app item p (item p mat)
      let aqq item q (item q mat)
      let apq item q (item p mat)

      let tau ((aqq - app) / (2 * apq))
      let t 0

      ifelse tau >= 0
      [ set t (1 / (tau + sqrt (1 + tau * tau))) ]
      [ set t (-1 / ((- tau) + sqrt (1 + tau * tau))) ]

      let c (1 / sqrt (1 + t * t))
      let s (t * c)

      ;; actualizar filas/columnas p y q
      let r 0
      while [r < n] [
        if (r != p) and (r != q) [
          let arp item p (item r mat)
          let arq item q (item r mat)

          let new-arp (c * arp - s * arq)
          let new-arq (s * arp + c * arq)

          set mat matrix-set mat r p new-arp
          set mat matrix-set mat p r new-arp

          set mat matrix-set mat r q new-arq
          set mat matrix-set mat q r new-arq
        ]
        set r r + 1
      ]

      let new-app (c * c * app - 2 * s * c * apq + s * s * aqq)
      let new-aqq (s * s * app + 2 * s * c * apq + c * c * aqq)

      set mat matrix-set mat p p new-app
      set mat matrix-set mat q q new-aqq
      set mat matrix-set mat p q 0
      set mat matrix-set mat q p 0
    ]

    set sweep sweep + 1
  ]

  report matrix-diagonal mat
end



;;-----------
;;Cálculo de las dos primeras frecuencias naturales
;;.............

to-report first-two-natural-frequencies-with-rotations [design jacobi-rotations]
  let global-k assemble-global-stiffness design
  let global-m assemble-global-mass design

  let reduced-k submatrix-by-indices global-k free-dofs
  let reduced-m submatrix-by-indices global-m free-dofs

  let standard-a generalized-to-standard-matrix-full reduced-k reduced-m

  if standard-a = nobody [
    report (list 0 0)
  ]

  let eigvals jacobi-eigenvalues standard-a 1.0e-10 jacobi-rotations
  let positive-eigvals sort (filter [lam -> lam > 1.0e-10] eigvals)

  if length positive-eigvals < 2 [
    report (list 0 0)
  ]

  let lambda-1 item 0 positive-eigvals
  let lambda-2 item 1 positive-eigvals

  let frequency-1 (sqrt lambda-1 / (2 * pi))
  let frequency-2 (sqrt lambda-2 / (2 * pi))

  report (list frequency-1 frequency-2)
end

to-report first-two-natural-frequencies [design]
  report first-two-natural-frequencies-with-rotations design 12000
end





;; peso real del domo
to-report compute-real-weight [design]
  let member-areas expand-design-to-members design
  let total-weight 0
  let elem-index 0

  while [elem-index < length member-areas] [
    let area-value item elem-index member-areas
    let member-length item elem-index member-lengths

    set total-weight total-weight + (effective-density * area-value * member-length)
    set elem-index elem-index + 1
  ]

  report total-weight
end


; ----------------------------------------------------------
; FITNESS
; ----------------------------------------------------------
to-report evaluate-design-120 [design]
  let weight compute-real-weight design

  let freqs first-two-natural-frequencies design
  let frequency-1 item 0 freqs
  let frequency-2 item 1 freqs

  let violation 0

  if frequency-1 < min-frequency-1 [
    set violation violation + ((min-frequency-1 - frequency-1) / min-frequency-1)
  ]

  if frequency-2 < min-frequency-2 [
    set violation violation + ((min-frequency-2 - frequency-2) / min-frequency-2)
  ]

  let progress 0
  if max-iterations > 0 [
    set progress (ticks / max-iterations)
  ]
  if progress > 1 [ set progress 1 ]

  let penalty-exponent (1.5 + 1.5 * progress)

  report ((1 + violation) ^ penalty-exponent) * weight
end





; ----------------------------------------------------------
; MEJOR GLOBAL INICIAL
; ----------------------------------------------------------

to initialize-global-best
  sync-global-best
end


to recompute-global-best
  if not any? particles [
    set g-best-vars []
    set g-best-val 1.0E+20
    stop
  ]

  let best-particle min-one-of particles [p-best-val]
  let best-design [p-best-vars] of best-particle
  let best-value [p-best-val] of best-particle

  set g-best-vars copy-design best-design
  set g-best-val best-value
end



; ----------------------------------------------------------
; GENERAR UN DISEÑO ALEATORIO DENTRO DE LÍMITES
; ----------------------------------------------------------
to-report random-design
  report random-vector-between lower-bounds upper-bounds
end

; ----------------------------------------------------------
; ACTUALIZAR MEJORES PERSONALES Y GLOBAL
; ----------------------------------------------------------
to update-personal-global-best
  ask particles [
    set current-val evaluate-design vars

    if current-val < p-best-val [
      set p-best-val current-val
      set p-best-vars (list
        (item 0 vars)
        (item 1 vars)
        (item 2 vars)
        (item 3 vars)
        (item 4 vars)
        (item 5 vars)
        (item 6 vars)
      )
    ]
  ]

  sync-global-best
end




; ==========================================================
; BUCLE PRINCIPAL — CSA VECTORIAL
; ==========================================================
to go
  ;; si quieres parar en un máximo de iteraciones:
  if ticks >= max-iterations [ stop ]

  ;; 1) Actualizar mejores con posiciones actuales
  update-personal-global-best
  let best-design best-design-now

  if (not is-list? best-design) or empty? best-design [
    stop
  ]

  ;; 2) μ(t): decaimiento lineal exploración → explotación
  let tau (ticks / max-iterations)
  if tau > 1 [ set tau 1 ]
  let mu (mu-max - (mu-max - mu-min) * tau)

  ;; 3) CSA por partícula: Percepción → Rotación → Caza
  ask particles [

    ;; ── Fase 1: Percepción / Búsqueda ─────────────────────
    ;; Con prob. Pp → exploración aleatoria
    ;; Con prob. 1-Pp → paso hacia p-best o g-best
    ifelse (random-float 1.0 < Pp)
    [
      let rand-dir random-uniform-vector number-of-groups
      let step (vec-scale (mu * attraction-to-personal-best) rand-dir)

      set vars (vec-clip (vec-add vars step) lower-bounds upper-bounds)
    ]
    [
      ifelse (random-float 1.0 < 0.5)
      [
        ;; Movimiento normalizado hacia mejor personal
        let d (vec-sub p-best-vars vars)
        let nd vec-norm d

        if nd > 0 [
          let step (vec-scale (mu * attraction-to-personal-best / nd) d)
          set vars (vec-clip (vec-add vars step) lower-bounds upper-bounds)
        ]
      ]
      [
        ;; Movimiento normalizado hacia mejor global
        let d (vec-sub best-design vars)
        let nd vec-norm d

        if nd > 0 [
          let step (vec-scale (mu * attraction-to-personal-best / nd) d)
          set vars (vec-clip (vec-add vars step) lower-bounds upper-bounds)
        ]
      ]
    ]

    ;; ── Fase 2: Rotación ocular / perturbación local ──────
    ;; En N dimensiones lo modelamos como una perturbación aleatoria suave
    let eye-step (mu * 0.5 * (0.5 + random-float 0.5))
    let noise (vec-scale eye-step (random-uniform-vector number-of-groups))

    set vars (vec-clip (vec-add vars noise) lower-bounds upper-bounds)

    ;; ── Fase 3: Caza / proyección de lengua ───────────────
    let r1 random-float 1.0
    let r2 random-float 1.0

    let term1 (vec-scale r1 (vec-sub p-best-vars vars))
    let term2 (vec-scale r2 (vec-sub best-design vars))
    let acc (vec-scale (attraction-to-global-best / 2) (vec-add term1 term2))

    set vel (vec-add (vec-scale particle-inertia vel) acc)

    ;; Limitar velocidad por componente
    set vel (vec-limit-components vel particle-speed-limit)

    ;; Aplicar movimiento
    set vars (vec-clip (vec-add vars vel) lower-bounds upper-bounds)
  ]

  update-plots
  tick
end

; ==========================================================
; EVALUACIÓN DE LA SOLUCIÓN
; ==========================================================

to-report evaluate-design [design]
  report evaluate-design-120 design
end


; ==========================================================
; UTILIDADES VECTORIALES
; ==========================================================

to-report vec-add [a b]
  report (map [[x y] -> x + y] a b)
end

to-report vec-sub [a b]
  report (map [[x y] -> x - y] a b)
end

to-report vec-scale [s a]
  report (map [x -> s * x] a)
end

to-report vec-norm [a]
  report sqrt (sum (map [x -> x * x] a))
end

to-report vec-clip [a low high]
  report (map [[x lo hi] -> max list lo (min list x hi)] a low high)
end

to-report vec-limit-components [a lim]
  report (map [x -> max list (- lim) (min list x lim)] a)
end

to-report random-vector-between [low high]
  report (map [[lo hi] -> lo + random-float (hi - lo)] low high)
end

to-report random-normal-vector [n sigma]
  report n-values n [ -> random-normal 0 sigma ]
end

to-report random-uniform-vector [n]
  report n-values n [ -> (random-float 2 - 1) ]
end










