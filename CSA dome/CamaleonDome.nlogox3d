end


to print-weight-breakdown-for-design [design]
  let expected-counts member-group-counts
  let start-index 0
  let group-index 0
  let total-weight 0

  show "=============================================="
  show "DESGLOSE DE PESO POR GRUPO"
  show "=============================================="

  while [group-index < length design] [
    let area-cm2 item group-index design
    let area-m2 (area-cm2 * 1.0e-4)
    let group-size item group-index expected-counts

    let group-weight 0
    let local-index 0

    while [local-index < group-size] [
      let elem-index (start-index + local-index)
      let member-length item elem-index member-lengths
      set group-weight group-weight + (effective-density * area-m2 * member-length)
      set local-index local-index + 1
    ]

    set total-weight total-weight + group-weight

    show (word
      "Grupo " (group-index + 1)
      " | area = " precision area-cm2 6 " cm^2"
      " | barras = " group-size
      " | peso grupo = " precision group-weight 6 " kg"
    )

    set start-index (start-index + group-size)
    set group-index (group-index + 1)
  ]

  show "----------------------------------------------"
  show (word "PESO TOTAL = " precision total-weight 6 " kg")
  show "=============================================="
end

to print-group-length-breakdown
  let start-index 0
  let group-index 0

  show "=============================================="
  show "LONGITUD TOTAL POR GRUPO"
  show "=============================================="

  while [group-index < length member-group-counts] [
    let group-size item group-index member-group-counts
    let group-length-total 0
    let local-index 0

    while [local-index < group-size] [
      let elem-index (start-index + local-index)
      set group-length-total group-length-total + (item elem-index member-lengths)
      set local-index local-index + 1
    ]

    show (word
      "Grupo " (group-index + 1)
      " | barras = " group-size
      " | longitud total = " precision group-length-total 6 " m"
    )

    set start-index (start-index + group-size)
    set group-index (group-index + 1)
  ]

  show "=============================================="
end


to print-jacobi-rotation-study [design]
  let rotation-list [2000 5000 12000 20000 40000]

  show "=============================================="
  show "ESTUDIO DE CONVERGENCIA DE JACOBI"
  show "=============================================="

  foreach rotation-list [nrot ->
    let freqs first-two-natural-frequencies-with-rotations design nrot
    show (word
      "rotaciones = " nrot
      " | f1 = " precision (item 0 freqs) 6 " Hz"
      " | f2 = " precision (item 1 freqs) 6 " Hz"
    )
  ]

  show "=============================================="
end

