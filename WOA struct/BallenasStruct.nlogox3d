;; Desplazamiento máximo en X,Y SOLO del nodo 17
to-report max-node17-displacement-xy [full-u]
  let dofs node-dof-indices 17
  let ux abs (item (item 0 dofs) full-u)
  let uy abs (item (item 1 dofs) full-u)
  report max (list ux uy)
end

to-report benchmark-case1-node17-disp
  let u benchmark-case1-displacements
  report max-node17-displacement-xy u
end

to-report benchmark-case2-node17-disp
