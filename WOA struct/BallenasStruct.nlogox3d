    if g-best-val < last-printed-best [
      show (word
        "tick=" ticks
        " | NUEVO_MEJOR"
        " | gbest=" precision g-best-val 4
        " | peso=" precision best-real-weight 4
        " | pen=" precision best-penalty 4
        " | viol_total=" precision best-total-violation 6
        " | viol_sigma=" precision best-total-stress-violation 6
        " | viol_disp=" precision best-total-disp-violation 6
        " | factible=" best-feasible?
        " | s1=" precision best-case1-max-stress 4
        " | s2=" precision best-case2-max-stress 4
        " | d1=" precision best-case1-max-disp 6
        " | d2=" precision best-case2-max-disp 6
      )
      set last-printed-best g-best-val
    ]
  ]
end

to print-geometry-validation
  show (word "NODOS=" model-node-count
       " | BARRAS=" model-member-count
       " | APOYOS=" model-support-count
       " | NODOS_TOP=" model-top-node-count)

  show (word "Z_BASE=" base-node-z-values
       " | Z_TOP=" top-node-z-values)

  show (word "BARRAS_POR_GRUPO=" member-counts-per-group)

  show (word "LONGITUDES_UNICAS=" unique-member-lengths)

  show (word "FRECUENCIAS_LONGITUD=" member-length-frequencies)
end

;; resultado final
to-report g-best-vars-text
  report (word
    "A1=" item 0 g-best-vars
    "  A2=" item 1 g-best-vars
    "  A3=" item 2 g-best-vars
    "  A4=" item 3 g-best-vars
    "  A5=" item 4 g-best-vars
    "  A6=" item 5 g-best-vars
    "  A7=" item 6 g-best-vars
    "  A8=" item 7 g-best-vars
    "  A9=" item 8 g-best-vars
    "  A10=" item 9 g-best-vars
    "  A11=" item 10 g-best-vars
    "  A12=" item 11 g-best-vars
    "  A13=" item 12 g-best-vars
    "  A14=" item 13 g-best-vars
    "  A15=" item 14 g-best-vars
    "  A16=" item 15 g-best-vars
  )
end




;; FUNCION PRINCIPAL DE OPTIMIZACION SEGUN EL ALGORITMO WOA

to go
  if ticks >= max-ticks [ stop ]

  ask particles [
    ;; Parametro a del WOA: baja linealmente de 2 a 0
    let a 2 * (1 - ticks / max-ticks)

    ;; coeficientes aleatorios
    let r1 random-float 1
    let r2 random-float 1

    let A-woa (2 * a * r1) - a
    let C-woa 2 * r2

    let p random-float 1
    let new-vars vars

    ;; FASE 1: encerramiento / exploracion
    if p < 0.5 [
      ;; explotacion: acercarse al mejor global
      if abs A-woa < 1 [
        set new-vars move-towards-target vars g-best-vars A-woa C-woa
      ]

      ;; exploracion: ir hacia una ballena aleatoria
      if abs A-woa >= 1 [
        let rand-whale one-of other particles
        if rand-whale = nobody [
          set rand-whale self
        ]
        set new-vars move-towards-target vars [vars] of rand-whale A-woa C-woa
      ]
    ]

    ;; FASE 2: movimiento en espiral
    if p >= 0.5 [
      let b woa-spiral-b
      let l (random-float 2) - 1
      set new-vars spiral-move vars g-best-vars b l
    ]

    ;; llevar la solucion a las secciones discretas permitidas
    set vars snap-design new-vars
  ]

  update-personal-global-best
  update-convergence-plot
  maybe-print-debug


  tick
end


