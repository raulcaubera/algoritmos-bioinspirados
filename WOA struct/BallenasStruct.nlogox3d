  report max-node17-displacement-xy u
end

;; Devuelve (nodo, dispXY) para todos los nodos superiores
to-report top-node-displacements-xy [full-u]
  let result []
  foreach top-node-ids [ nid ->
    let dofs node-dof-indices nid
    let ux abs (item (item 0 dofs) full-u)
    let uy abs (item (item 1 dofs) full-u)
    set result lput (list nid (max (list ux uy))) result
  ]
  report result
end

to-report benchmark-case2-top-node-disps
