<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 3D 7.0.3" snapToGrid="false">
  <code><![CDATA[;; --- MODELO ESTRUCTURAL 72-BAR ---
;; Geometría, conectividad, apoyos y casos de carga
;; Reproduce el benchmark clásico de la literatura (Kaveh et al.)


;Slider stress-limit límite de tensión admisible en psi.
;Slider displacement-limit límite de desplazamiento admisible en pulgadas
;Slider young-modulus módulo de elasticidad E, en psi
;Slider density densidad del material, en lb/in³

breed [ particles particle ]

globals [
  g-best-vars          ;; mejor solucion global: lista de 16 variables
  g-best-val           ;; mejor fitness global
  max-ticks            ;; numero maximo de iteraciones realmente usado

  sections             ;; lista de secciones discretas disponibles
  number-of-groups     ;; numero de variables de diseño (16)
  section-count        ;; numero de secciones discretas (64)
  section-min          ;; area minima disponible
  section-max          ;; area maxima disponible

  best-weight          ;; peso sin penalizar de la mejor solucion
  best-penalty         ;; penalizacion de la mejor solucion
  
  member-group-limits  ;; rangos de barras 
  
  node-coords           ;; coordenadas de los 20 nodos
  member-connectivity   ;; conectividad de las 72 barras
  member-lengths        ;; longitud de cada barra
  support-node-ids      ;; nodos apoyados
  load-case-1           ;; caso de carga 1 del PDF
  load-case-2           ;; caso de carga 2 del PDF

  total-dofs            ;; numero total de grados de libertad
  restrained-dofs       ;; lista de dofs restringidos por los apoyos
  free-dofs             ;; lista de dofs libres
  
  top-node-ids          ;; nodos superiores 17–20
  
  
  debug-mode?          ;; activa o desactiva mensajes de depuracion
  debug-every          ;; cada cuantos ticks imprimir resumen
  
  last-printed-best
  
  benchmark-72bar-design
  benchmark-72bar-weight

]

particles-own [
  vars                 ;; solucion actual de la particula: lista de 16 variables
  p-best-vars          ;; mejor solucion personal
  p-best-val           ;; mejor fitness personal
  current-val          ;; fitness actual
]



;; INICIALIZACION
to setup
  clear-all
  reset-ticks
  
  set-problem-constants
  set-sections
  build-72bar-model

  set max-ticks max-iterations

  initialize-particles
  initialize-global-best

  set-current-plot "Convergencia"
  clear-plot

  ;set debug-mode? true
  set debug-mode? false
  set debug-every 10
  set last-printed-best 1.0E+20
  
 
  
end


;; 72-bar: 16 grupos y 64 secciones discretas entre 0.111 y 33.5 in
to set-problem-constants
  ;; datos estructurales fijos del benchmark
  set number-of-groups 16
  set section-count 64
  set section-min 0.111
  set section-max 33.5

  ;; valores auxiliares para monitores
  set best-weight 0
  set best-penalty 0
  
  set member-group-limits [
    [1 4]
    [5 12]
    [13 16]
    [17 18]
    [19 22]
    [23 30]
    [31 34]
    [35 36]
    [37 40]
    [41 48]
    [49 52]
    [53 54]
    [55 58]
    [59 66]
    [67 70]
    [71 72]
  ]
  
  ;; 20 nodos y cada nodo de una celosía espacial tiene 3 DOFs (x, y, z), así que en total son 60
  set total-dofs 60
  
  ;;;; nodos superiores 17–20
  set top-node-ids [17 18 19 20]
    
  
  ;; Diseño benchmark publicado en la Tabla 4.5 para WOA / EWOA
  set benchmark-72bar-design [
    1.99 0.563 0.111 0.111
    1.228 0.442 0.111 0.111
    0.563 0.563 0.111 0.111
    0.196 0.563 0.391 0.563
  ]

  ;; Peso benchmark publicado
  set benchmark-72bar-weight 389.33
end


;; Lista fija real de 64 areas discretas del problema
to set-sections

  set sections [
    0.111 0.141 0.196 0.250 0.307 0.391 0.442 0.563
    0.602 0.766 0.785 0.994 1.000 1.228 1.266 1.457
    1.563 1.620 1.800 1.990 2.130 2.380 2.620 2.630
    2.880 2.930 3.090 3.130 3.380 3.470 3.550 3.630
    3.840 3.870 3.880 4.100 4.220 4.490 4.590 4.800
    4.970 5.120 5.740 7.220 7.970 8.530 9.300 10.850
    11.500 13.500 13.900 14.200 15.500 16.000 16.900 18.800
    19.900 22.000 22.900 24.500 26.500 28.000 30.000 33.500
  ]

  ;; actualizar metadatos para que todo el modelo quede coherente
  set section-count length sections
  set section-min first sections
  set section-max last sections
end


;;Construir el modelo reconstruido de 72 barras
to build-72bar-model
  ;; Reconstruccion consistente del benchmark:
  ;; 5 niveles, 4 nodos por nivel, planta cuadrada de 120x120 in,
  ;; 4 modulos verticales de 60 in de altura.

  set node-coords [
    [0   0   0]
    [120 0   0]
    [120 120 0]
    [0   120 0]

    [0   0   60]
    [120 0   60]
    [120 120 60]
    [0   120 60]

    [0   0   120]
    [120 0   120]
    [120 120 120]
    [0   120 120]

    [0   0   180]
    [120 0   180]
    [120 120 180]
    [0   120 180]

    [0   0   240]
    [120 0   240]
    [120 120 240]
    [0   120 240]
  ]

  ;; base apoyada
  set support-node-ids [1 2 3 4]

  ;; dos casos de carga del PDF
  ;; caso 1: carga vertical en los nodos superiores
  set load-case-1 [
    [17 0     0    -5000]
    [18 0     0    -5000]
    [19 0     0    -5000]
    [20 0     0    -5000]
  ]

  ;; caso 2: carga combinada en el nodo 17
  set load-case-2 [
    [17 5000 5000 -5000]
    [18 0     0     0]
    [19 0     0     0]
    [20 0     0     0]
  ]

  ;; conectividad: 4 modulos de 18 barras = 72 barras
  set member-connectivity []
  set member-connectivity sentence member-connectivity (module-members 1)
  set member-connectivity sentence member-connectivity (module-members 5)
  set member-connectivity sentence member-connectivity (module-members 9)
  set member-connectivity sentence member-connectivity (module-members 13)

  ;; calcular longitudes de las 72 barras
  set member-lengths []
  let i 0
  while [i < length member-connectivity] [
  let conn item i member-connectivity
  let ni first conn
  let nj last conn
  set member-lengths lput (distance-between-nodes ni nj) member-lengths
  set i i + 1
  ]
  set restrained-dofs build-restrained-dofs
  set free-dofs build-free-dofs
end


;;Miembros de un módulo de 18 barras, la conectividad encaja con el patrón de grupos  (4 / 8 / 4 / 2 repetido cuatro veces) y con el esquema de torre espacial del problema
to-report module-members [base-node]
  let lower1 base-node
  let lower2 (base-node + 1)
  let lower3 (base-node + 2)
  let lower4 (base-node + 3)

  let upper1 (base-node + 4)
  let upper2 (base-node + 5)
  let upper3 (base-node + 6)
  let upper4 (base-node + 7)

  report (list
    ;; 4 verticales
    (list lower1 upper1)
    (list lower2 upper2)
    (list lower3 upper3)
    (list lower4 upper4)

    ;; 8 diagonales laterales
    (list lower1 upper2)
    (list lower2 upper1)

    (list lower2 upper3)
    (list lower3 upper2)

    (list lower3 upper4)
    (list lower4 upper3)

    (list lower4 upper1)
    (list lower1 upper4)

    ;; 4 horizontales del nivel superior
    (list upper1 upper2)
    (list upper2 upper3)
    (list upper3 upper4)
    (list upper4 upper1)

    ;; 2 diagonales en planta del nivel superior
    (list upper1 upper3)
    (list upper2 upper4)
  )
end

;;Obtener coordenadas de un nodo
to-report node-xyz [node-id]
  report item (node-id - 1) node-coords
end

;;Distancia entre dos nodos
to-report distance-between-nodes [ni nj]
  let p node-xyz ni
  let q node-xyz nj

  let delta-x ((item 0 q) - (item 0 p))
  let delta-y ((item 1 q) - (item 1 p))
  let delta-z ((item 2 q) - (item 2 p))

  report sqrt (delta-x * delta-x + delta-y * delta-y + delta-z * delta-z)
end


;;DOFs de un nodo
to-report node-dof-indices [node-id]
  let base (3 * (node-id - 1))
  report (list base (base + 1) (base + 2))
end

;;Construir DOFs restringidos
to-report build-restrained-dofs
  let result []
  let i 0

  while [i < length support-node-ids] [
    let node-id item i support-node-ids
    let dofs node-dof-indices node-id

    set result sentence result dofs
    set i i + 1
  ]

  report result
end

;;Construir DOFs libres
to-report build-free-dofs
  let result []
  let d 0

  while [d < total-dofs] [
    if not member? d restrained-dofs [
      set result lput d result
    ]
    set d d + 1
  ]

  report result
end

;;Vector global de cargas para un caso
to-report load-vector-from-case [one-load-case]
  let force-vector n-values total-dofs [ i -> 0 ]
  let i 0

  while [i < length one-load-case] [
    let load-entry item i one-load-case

    let node-id item 0 load-entry
    let force-x item 1 load-entry
    let force-y item 2 load-entry
    let force-z item 3 load-entry

    let dof-list node-dof-indices node-id

    set force-vector (replace-item (item 0 dof-list) force-vector force-x)
    set force-vector (replace-item (item 1 dof-list) force-vector force-y)
    set force-vector (replace-item (item 2 dof-list) force-vector force-z)

    set i i + 1
  ]

  report force-vector
end

  
;;Ceros: vector y matriz
to-report zero-vector [n]
  report n-values n [ i -> 0 ]
end

to-report zero-matrix [rows cols]
  report n-values rows [ r -> n-values cols [ c -> 0 ] ]
end

;;Reemplazar un valor en una matriz
to-report matrix-set [mat row-index col-index new-value]
  let selected-row item row-index mat
  let updated-row replace-item col-index selected-row new-value
  report replace-item row-index mat updated-row
end


;;Sumar a una posición concreta de la matriz
to-report matrix-add [mat row-index col-index increment]
  let current-value item col-index (item row-index mat)
  report matrix-set mat row-index col-index (current-value + increment)
end


;;DOFs de un elemento
to-report element-dof-indices [node-i node-j]
  report sentence (node-dof-indices node-i) (node-dof-indices node-j)
end

;;Matriz de rigidez 3D de una barra espacial
;;formulación estándar de una barra de celosía 3D en coordenadas globales: depende de la longitud, del área, de young-modulus y de los cosenos directores (slider young-modulus)
to-report element-stiffness-3d [area node-i node-j]
  let coord-i (node-xyz node-i)
  let coord-j (node-xyz node-j)

  let x1 item 0 coord-i
  let y1 item 1 coord-i
  let z1 item 2 coord-i

  let x2 item 0 coord-j
  let y2 item 1 coord-j
  let z2 item 2 coord-j

  let delta-x (x2 - x1)
  let delta-y (y2 - y1)
  let delta-z (z2 - z1)

  let elem-length sqrt (delta-x * delta-x + delta-y * delta-y + delta-z * delta-z)

  let cos-x (delta-x / elem-length)
  let cos-y (delta-y / elem-length)
  let cos-z (delta-z / elem-length)

  let coeff (young-modulus * area / elem-length)

  report (list
    (list (coeff * cos-x * cos-x) (coeff * cos-x * cos-y) (coeff * cos-x * cos-z)
          (- coeff * cos-x * cos-x) (- coeff * cos-x * cos-y) (- coeff * cos-x * cos-z))

    (list (coeff * cos-x * cos-y) (coeff * cos-y * cos-y) (coeff * cos-y * cos-z)
          (- coeff * cos-x * cos-y) (- coeff * cos-y * cos-y) (- coeff * cos-y * cos-z))

    (list (coeff * cos-x * cos-z) (coeff * cos-y * cos-z) (coeff * cos-z * cos-z)
          (- coeff * cos-x * cos-z) (- coeff * cos-y * cos-z) (- coeff * cos-z * cos-z))

    (list (- coeff * cos-x * cos-x) (- coeff * cos-x * cos-y) (- coeff * cos-x * cos-z)
          (coeff * cos-x * cos-x) (coeff * cos-x * cos-y) (coeff * cos-x * cos-z))

    (list (- coeff * cos-x * cos-y) (- coeff * cos-y * cos-y) (- coeff * cos-y * cos-z)
          (coeff * cos-x * cos-y) (coeff * cos-y * cos-y) (coeff * cos-y * cos-z))

    (list (- coeff * cos-x * cos-z) (- coeff * cos-y * cos-z) (- coeff * cos-z * cos-z)
          (coeff * cos-x * cos-z) (coeff * cos-y * cos-z) (coeff * cos-z * cos-z))
  )
end


;;Ensamblar la matriz global del modelo (cogemos las 72 barras, calculamos la rigidez de cada una y la sumamos en la matriz global de tamaño 60 x 60)
to-report assemble-global-stiffness [design]
  let member-areas expand-design-to-members design
  let global-k zero-matrix total-dofs total-dofs

  let elem-index 0
  while [elem-index < length member-connectivity] [
    let elem-conn item elem-index member-connectivity
    let node-i first elem-conn
    let node-j last elem-conn

    let area item elem-index member-areas
    let elem-k element-stiffness-3d area node-i node-j
    let elem-dofs element-dof-indices node-i node-j

    let local-row 0
    while [local-row < 6] [
      let global-row item local-row elem-dofs

      let local-col 0
      while [local-col < 6] [
        let global-col item local-col elem-dofs
        let k-value item local-col (item local-row elem-k)

        set global-k matrix-add global-k global-row global-col k-value
        set local-col local-col + 1
      ]

      set local-row local-row + 1
    ]

    set elem-index elem-index + 1
  ]

  report global-k
end

;;Extraer un subvector por índices
to-report subvector-by-indices [full-vector index-list]
  let result []
  let idx-pos 0

  while [idx-pos < length index-list] [
    let dof-index item idx-pos index-list
    set result lput (item dof-index full-vector) result
    set idx-pos idx-pos + 1
  ]

  report result
end

;;Extraer una submatriz por índices
to-report submatrix-by-indices [full-matrix index-list]
  let result []
  let row-pos 0

  while [row-pos < length index-list] [
    let row-index item row-pos index-list
    let full-row item row-index full-matrix

    let reduced-row []
    let col-pos 0

    while [col-pos < length index-list] [
      let col-index item col-pos index-list
      set reduced-row lput (item col-index full-row) reduced-row
      set col-pos col-pos + 1
    ]

    set result lput reduced-row result
    set row-pos row-pos + 1
  ]

  report result
end

;;Resolver un sistema lineal por eliminación gaussiana
to-report gaussian-solve [input-matrix input-vector]
  let mat input-matrix
  let vec input-vector
  let n length vec

  let pivot-row 0
  while [pivot-row < n] [
    ;; buscar mejor pivote en la columna actual
    let best-row pivot-row
    let best-value abs (item pivot-row (item pivot-row mat))

    let search-row (pivot-row + 1)
    while [search-row < n] [
      let candidate abs (item pivot-row (item search-row mat))
      if candidate > best-value [
        set best-value candidate
        set best-row search-row
      ]
      set search-row search-row + 1
    ]

    ;; si la matriz es singular o casi singular
    if best-value <= 1.0e-12 [
      report zero-vector n
    ]

    ;; intercambio de filas si hace falta
    if best-row != pivot-row [
      let temp-row item pivot-row mat
      let swap-row item best-row mat
      set mat replace-item pivot-row mat swap-row
      set mat replace-item best-row mat temp-row

      let temp-val item pivot-row vec
      let swap-val item best-row vec
      set vec replace-item pivot-row vec swap-val
      set vec replace-item best-row vec temp-val
    ]

    ;; normalizar la fila pivote
    let pivot-value item pivot-row (item pivot-row mat)
    let pivot-row-list item pivot-row mat

    let col-index pivot-row
    while [col-index < n] [
      set pivot-row-list replace-item col-index pivot-row-list ((item col-index pivot-row-list) / pivot-value)
      set col-index col-index + 1
    ]

    set mat replace-item pivot-row mat pivot-row-list
    set vec replace-item pivot-row vec ((item pivot-row vec) / pivot-value)

    ;; eliminar por debajo
    let elim-row (pivot-row + 1)
    while [elim-row < n] [
      let factor item pivot-row (item elim-row mat)
      let row-list item elim-row mat

      let elim-col pivot-row
      while [elim-col < n] [
        set row-list replace-item elim-col row-list ((item elim-col row-list) - factor * (item elim-col pivot-row-list))
        set elim-col elim-col + 1
      ]

      set mat replace-item elim-row mat row-list
      set vec replace-item elim-row vec ((item elim-row vec) - factor * (item pivot-row vec))

      set elim-row elim-row + 1
    ]

    set pivot-row pivot-row + 1
  ]

  ;; sustitucion hacia atras
  let solution zero-vector n
  let row-index (n - 1)

  while [row-index >= 0] [
    let row-list item row-index mat
    let rhs item row-index vec

    let col-index (row-index + 1)
    while [col-index < n] [
      set rhs rhs - (item col-index row-list) * (item col-index solution)
      set col-index col-index + 1
    ]

    ;; como la diagonal ya esta normalizada a 1
    set solution replace-item row-index solution rhs
    set row-index row-index - 1
  ]

  report solution
end


;;Resolver desplazamientos para un caso de carga
to-report solve-displacements-for-case [design one-load-case]
  let global-k assemble-global-stiffness design
  let full-force load-vector-from-case one-load-case

  let reduced-k submatrix-by-indices global-k free-dofs
  let reduced-f subvector-by-indices full-force free-dofs

  let reduced-u gaussian-solve reduced-k reduced-f

  let full-u zero-vector total-dofs
  let i 0

  while [i < length free-dofs] [
    let dof-index item i free-dofs
    set full-u replace-item dof-index full-u (item i reduced-u)
    set i i + 1
  ]

  report full-u
end

;;Máximo valor absoluto de un vector
to-report max-abs-value [vec]
  let current-max 0
  let i 0

  while [i < length vec] [
    let abs-value abs (item i vec)
    if abs-value > current-max [
      set current-max abs-value
    ]
    set i i + 1
  ]

  report current-max
end


;;Extraer el vector de desplazamientos de un elemento
to-report element-displacement-vector [full-u node-i node-j]
  let dof-list element-dof-indices node-i node-j
  let result []
  let i 0

  while [i < length dof-list] [
    set result lput (item (item i dof-list) full-u) result
    set i i + 1
  ]

  report result
end


;;Tensión axial de una barra 3D fórmula estándar de una barra de celosía 3D: la deformación axial se calcula proyectando los desplazamientos en la dirección de la barra, y luego: σ=EL ΔL\sigma = \frac{E}{L}\,\Delta Lσ=LE​ΔL
to-report element-axial-stress [full-u node-i node-j]
  let coord-i (node-xyz node-i)
  let coord-j (node-xyz node-j)

  let x1 item 0 coord-i
  let y1 item 1 coord-i
  let z1 item 2 coord-i

  let x2 item 0 coord-j
  let y2 item 1 coord-j
  let z2 item 2 coord-j

  let delta-x (x2 - x1)
  let delta-y (y2 - y1)
  let delta-z (z2 - z1)

  let elem-length sqrt (delta-x * delta-x + delta-y * delta-y + delta-z * delta-z)

  let cos-x (delta-x / elem-length)
  let cos-y (delta-y / elem-length)
  let cos-z (delta-z / elem-length)

  let uelem element-displacement-vector full-u node-i node-j

  let axial-deformation
    (- cos-x * item 0 uelem
     - cos-y * item 1 uelem
     - cos-z * item 2 uelem
     + cos-x * item 3 uelem
     + cos-y * item 4 uelem
     + cos-z * item 5 uelem)

  report (young-modulus / elem-length) * axial-deformation
end

;;Máxima tensión absoluta de todas las barras en un caso 
to-report max-abs-stress-for-design [design full-u]
  let max-stress 0
  let elem-index 0

  while [elem-index < length member-connectivity] [
    let elem-conn item elem-index member-connectivity
    let node-i first elem-conn
    let node-j last elem-conn

    let stress abs (element-axial-stress full-u node-i node-j)

    if stress > max-stress [
      set max-stress stress
    ]

    set elem-index elem-index + 1
  ]

  report max-stress
end

;;Máximo desplazamiento en nodos superiores
to-report max-top-node-displacement [full-u]
  let max-disp 0
  let i 0

  while [i < length top-node-ids] [
    let node-id item i top-node-ids
    let dofs node-dof-indices node-id

    let ux abs (item (item 0 dofs) full-u)
    let uy abs (item (item 1 dofs) full-u)
    let uz abs (item (item 2 dofs) full-u)

    if ux > max-disp [ set max-disp ux ]
    if uy > max-disp [ set max-disp uy ]
    if uz > max-disp [ set max-disp uz ]

    set i i + 1
  ]

  report max-disp
end

;; en x y
to-report max-top-node-displacement-xy [full-u]
  let max-disp 0
  let i 0

  while [i < length top-node-ids] [
    let node-id item i top-node-ids
    let dofs node-dof-indices node-id

    let ux abs (item (item 0 dofs) full-u)
    let uy abs (item (item 1 dofs) full-u)

    if ux > max-disp [ set max-disp ux ]
    if uy > max-disp [ set max-disp uy ]

    set i i + 1
  ]

  report max-disp
end



;;======================================================================
;; VALIDACIÓN DEL MODELO (NO USADO EN LA OPTIMIZACIÓN)
;; Estos reporters se utilizan únicamente para comprobar:
;; - Reproducción del benchmark 72-bar
;; - Correcta aplicación de cargas y restricciones
;;======================================================================


;;reporters de prueba Tamaño de la matriz global
to-report global-stiffness-dimensions
  let k assemble-global-stiffness g-best-vars
  report (list (length k) (length first k))
end



;;Reporters de prueba
to-report case1-displacements
  report solve-displacements-for-case g-best-vars load-case-1
end

to-report case2-displacements
  report solve-displacements-for-case g-best-vars load-case-2
end

to-report case1-max-displacement
  report max-abs-value case1-displacements
end

to-report case2-max-displacement
  report max-abs-value case2-displacements
end

;; mas Reporters de prueba
to-report case1-max-stress
  let u solve-displacements-for-case g-best-vars load-case-1
  report max-abs-stress-for-design g-best-vars u
end

to-report case2-max-stress
  let u solve-displacements-for-case g-best-vars load-case-2
  report max-abs-stress-for-design g-best-vars u
end

to-report case1-top-displacement
  let u solve-displacements-for-case g-best-vars load-case-1
  report max-top-node-displacement u
end

to-report case2-top-displacement
  let u solve-displacements-for-case g-best-vars load-case-2
  report max-top-node-displacement u
end


;;REPORTERS Peso real del mejor diseño
to-report best-real-weight
  report compute-real-weight g-best-vars
end

;;reporetes Desplazamientos del mejor diseño en ambos casos
to-report best-case1-displacements
  report solve-displacements-for-case g-best-vars load-case-1
end

to-report best-case2-displacements
  report solve-displacements-for-case g-best-vars load-case-2
end

;;reporet Máximo esfuerzo del mejor diseño
to-report best-case1-max-stress
  let u best-case1-displacements
  report max-abs-stress-for-design g-best-vars u
end

to-report best-case2-max-stress
  let u best-case2-displacements
  report max-abs-stress-for-design g-best-vars u
end

;;reporert Máximo desplazamiento del mejor diseño en los nodos superiores
to-report best-case1-max-disp
  let u best-case1-displacements
  report max-top-node-displacement-xy u
end

to-report best-case2-max-disp
  let u best-case2-displacements
  report max-top-node-displacement-xy u
end


;;repoirtt Violación total del mejor diseño   usa exactamente la misma lógica que ya estás usando dentro de evaluate-design, pero solo para mostrarla en un monitor
to-report best-total-violation
  let stress1 best-case1-max-stress
  let stress2 best-case2-max-stress
  let disp1 best-case1-max-disp
  let disp2 best-case2-max-disp

  let violation 0

  if stress1 > stress-limit [
    set violation violation + ((stress1 - stress-limit) / stress-limit)
  ]

  if stress2 > stress-limit [
    set violation violation + ((stress2 - stress-limit) / stress-limit)
  ]

  if disp1 > displacement-limit [
    set violation violation + ((disp1 - displacement-limit) / displacement-limit)
  ]

  if disp2 > displacement-limit [
    set violation violation + ((disp2 - displacement-limit) / displacement-limit)
  ]

  report violation
end

;;Reporter de factibilidad  útil para saber si el mejor diseño actual cumple todo o no
to-report best-feasible?
  report (best-total-violation = 0)
end

;;Violación por tensión, caso 1
to-report best-stress-violation-case1
  let stress1 best-case1-max-stress
  ifelse stress1 > stress-limit
    [ report ((stress1 - stress-limit) / stress-limit) ]
    [ report 0 ]
end

;;Violación por tensión, caso 2
to-report best-stress-violation-case2
  let stress2 best-case2-max-stress
  ifelse stress2 > stress-limit
    [ report ((stress2 - stress-limit) / stress-limit) ]
    [ report 0 ]
end

;;Violación por desplazamiento, caso 1
to-report best-disp-violation-case1
  let disp1 best-case1-max-disp
  ifelse disp1 > displacement-limit
    [ report ((disp1 - displacement-limit) / displacement-limit) ]
    [ report 0 ]
end

;;Violación por desplazamiento, caso 2
to-report best-disp-violation-case2
  let disp2 best-case2-max-disp
  ifelse disp2 > displacement-limit
    [ report ((disp2 - displacement-limit) / displacement-limit) ]
    [ report 0 ]
end

;;Suma de violación por tensión
to-report best-total-stress-violation
  report best-stress-violation-case1 + best-stress-violation-case2
end

;;Suma de violación por desplazamiento
to-report best-total-disp-violation
  report best-disp-violation-case1 + best-disp-violation-case2
end

;;contadores basicos
to-report model-node-count
  report length node-coords
end

to-report model-member-count
  report length member-connectivity
end

to-report model-support-count
  report length support-node-ids
end

to-report model-top-node-count
  report length top-node-ids
end

;;alturas de base y coronacion
to-report base-node-z-values
  let result []
  let i 0

  while [i < length support-node-ids] [
    let node-id item i support-node-ids
    let xyz node-xyz node-id
    set result lput (item 2 xyz) result
    set i i + 1
  ]

  report result
end

to-report top-node-z-values
  let result []
  let i 0

  while [i < length top-node-ids] [
    let node-id item i top-node-ids
    let xyz node-xyz node-id
    set result lput (item 2 xyz) result
    set i i + 1
  ]

  report result
end

;;Conteo de barras por grupo, comprueba si la lista member-group-limits encaja con 72 barras
to-report member-counts-per-group
  let result []
  let i 0

  while [i < length member-group-limits] [
    let current-limits item i member-group-limits
    let first-id first current-limits
    let last-id last current-limits
    set result lput ((last-id - first-id) + 1) result
    set i i + 1
  ]

  report result
end

;;Longitudes redondeadas de las barras, para validar la topología, es muy útil ver qué longitudes aparecen realmente
to-report rounded-member-lengths
  let result []
  let i 0

  while [i < length member-lengths] [
    let L item i member-lengths
    ;; redondeo a 3 decimales
    let rounded-L (precision L 3)
    set result lput rounded-L result
    set i i + 1
  ]

  report result
end

;;conjunto de longitudes uncias
to-report unique-member-lengths
  let unique-list []
  let lengths rounded-member-lengths
  let i 0

  while [i < length lengths] [
    let current-L item i lengths
    if not member? current-L unique-list [
      set unique-list lput current-L unique-list
    ]
    set i i + 1
  ]

  report sort unique-list
  
end

;;frecuancia de cada longitud
to-report member-length-frequencies
  let uniques unique-member-lengths
  let result []
  let i 0

  while [i < length uniques] [
    let target-L item i uniques
    let count-L 0
    let j 0

    while [j < length member-lengths] [
      if (precision (item j member-lengths) 3) = target-L [
        set count-L count-L + 1
      ]
      set j j + 1
    ]

    set result lput (list target-L count-L) result
    set i i + 1
  ]

  report result
end
  

