;; Inicializar particulas en el espacio de busqueda
to initialize-particles
  ; Crear espacio de busqueda aleatorio 
  create-particles population-size [
    set vars random-design
    set current-val evaluate-design vars

    set p-best-vars vars
    set p-best-val current-val

    set color red
    set shape "dot"
    set size 2

  ]
end


;; mejor global incial
to initialize-global-best
  ask min-one-of particles [p-best-val] [
    set g-best-vars p-best-vars
    set g-best-val p-best-val
  ]

  set best-weight g-best-val
  set best-penalty 0
end


;;cada partícula arranque con una lista de 16 variables, una por grupo de barras
to-report random-design
  report n-values number-of-groups [ -> random-section ]
end


to-report random-section
  report item (random length sections) sections
end

;;nos deja preparada la estructura para que luego el cálculo real de peso/tensiones/desplazamientos trabaje con 72 elementos reales en vez de solo 16 variables abstractas
to-report expand-design-to-members [design]
  let member-areas []
  let g 0

  while [g < length design] [
    let area item g design
    let current-limits item g member-group-limits
    let start-member first current-limits
    let end-member last current-limits

    let m start-member
    while [m <= end-member] [
      set member-areas lput area member-areas
      set m m + 1
    ]

    set g g + 1
  ]

  report member-areas
end

;;Peso real de la estructura
to-report compute-real-weight [design]
  let member-areas expand-design-to-members design
  let total-weight 0
  let i 0

  while [i < length member-areas] [
    set total-weight total-weight +
      density * (item i member-areas) * (item i member-lengths)
    set i i + 1
  ]

  report total-weight
end



;; Función objetivo: minimización del peso con penalización progresiva
;; Se emplea un enfoque de penalty function, como en los benchmarks del 72-bar:
;;   fitness = (1 + violation)^p(t) * weight
;; donde p(t) aumenta con el número de iteraciones
to-report evaluate-design [design]
  let weight compute-real-weight design

  let u1 solve-displacements-for-case design load-case-1
  let u2 solve-displacements-for-case design load-case-2

  let max-stress-1 max-abs-stress-for-design design u1
  let max-stress-2 max-abs-stress-for-design design u2
  
  ;let max-disp-1 max-top-node-displacement u1
  ;let max-disp-2 max-top-node-displacement u2
  let max-disp-1 max-top-node-displacement-xy u1
  let max-disp-2 max-top-node-displacement-xy u2

  let violation 0

  if max-stress-1 > stress-limit [
    set violation violation + ((max-stress-1 - stress-limit) / stress-limit)
  ]

  if max-stress-2 > stress-limit [
    set violation violation + ((max-stress-2 - stress-limit) / stress-limit)
  ]

  if max-disp-1 > displacement-limit [
    set violation violation + ((max-disp-1 - displacement-limit) / displacement-limit)
  ]

  if max-disp-2 > displacement-limit [
    set violation violation + ((max-disp-2 - displacement-limit) / displacement-limit)
  ]

  ;; penalizacion tipo benchmark: aumenta durante las iteraciones
  let penalty-exponent (1.5 + 1.5 * ticks / max-ticks)

  report ((1 + violation) ^ penalty-exponent) * weight
end


;; Actualizar mejores personales y global
to update-personal-global-best
  ask particles [
    set current-val evaluate-design vars

    if current-val < p-best-val [
      set p-best-val current-val
      set p-best-vars vars
    ]
  ]

  ask min-one-of particles [p-best-val] [
    if p-best-val < g-best-val [
      set g-best-val p-best-val
      set g-best-vars p-best-vars
    ]
  ]

  let current-best-weight compute-real-weight g-best-vars
  set best-weight current-best-weight
  set best-penalty (g-best-val - current-best-weight)
end



;; Redondear una variable a la sección permitida más cercana
to-report snap-section [value]
  let nearest first sections
  let best-diff abs (value - nearest)

  foreach but-first sections [ s ->
    let d abs (value - s)
    if d < best-diff [
      set nearest s
      set best-diff d
    ]
  ]

  report nearest
end


;; Redondear una solución completa (16 variables)
to-report snap-design [design]
  let result []
  let i 0

  while [i < length design] [
    set result lput (snap-section (item i design)) result
    set i i + 1
  ]

  report result
end


;; Movimiento WOA hacia el mejor global
to-report move-towards-target [current-design target-design A-woa C-woa]
  let result []
  let i 0

  while [i < length current-design] [
    let x item i current-design
    let t item i target-design
    set result lput (t - A-woa * abs (C-woa * t - x)) result
    set i i + 1
  ]

  report result
end

;; Movimiento en espiral WOA, el movimiento en espiral se aplica componente a componente para la lista de 16 variables
to-report spiral-move [current-design target-design b l]
  let spiral-factor exp (b * l) * cos (360 * l)
  let result []
  let i 0

  while [i < length current-design] [
    let x item i current-design
    let t item i target-design
    set result lput (abs (t - x) * spiral-factor + t) result
    set i i + 1
  ]

  report result
end


;; Actualizar el plot de convergencia
to update-convergence-plot
  set-current-plot "Convergencia"

  set-current-plot-pen "best"
  plot g-best-val

  set-current-plot-pen "mean"
  plot mean [current-val] of particles
end



;; mostrar en cconslola daots
to maybe-print-debug
